@model MyCourierSA.Models.Shipment
@{
    Layout = null;
    ViewBag.Title = "Tracking Result";

    // 1. Define the Labels
    string[] labels = { "Booked", "Collected", "In Warehouse", "In Transit", "Delivered" };

    // 2. ADD THIS: Define the Icons array
    string[] icons = { "bi-receipt", "bi-box-arrow-up", "bi-building", "bi-truck", "bi-house-check-fill" };

    int currentStep = 0;
    if (Model != null)
    {
        if (Model.Status == "Pending" || Model.Status == "Approved") { currentStep = 0; }
        else if (Model.Status.Contains("Collection") || Model.Status == "Collected") { currentStep = 1; }
        else if (Model.Status == "At Warehouse") { currentStep = 2; }
        else if (Model.Status.Contains("Delivery") || Model.Status == "In Transit") { currentStep = 3; }
        else if (Model.Status == "Delivered") { currentStep = 4; }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        body {
            background: linear-gradient(135deg, rgba(15, 30, 50, 0.9), rgba(10, 15, 25, 0.95)), url('/Content/Images/courier-bg.jpg') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding: 40px 0;
        }

        .result-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 1.5rem;
            padding: 3rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            max-width: 850px;
            width: 95%;
            margin: auto;
        }

        .timeline-wrapper {
            position: relative;
            padding: 3rem 0;
        }

        .timeline-line {
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 4px;
            background: #e9ecef;
            transform: translateY(-50%);
            z-index: 1;
        }

        .timeline-progress {
            position: absolute;
            top: 50%;
            left: 0;
            height: 4px;
            background: #0d6efd;
            transform: translateY(-50%);
            z-index: 2;
            transition: width 1s ease;
        }

        .timeline-step {
            position: relative;
            z-index: 3;
            text-align: center;
            width: 20%;
        }

        .step-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #fff;
            border: 4px solid #e9ecef;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: #adb5bd;
            transition: 0.4s;
        }

        .completed .step-icon {
            border-color: #0d6efd;
            background: #0d6efd;
            color: #fff;
        }

        .active .step-icon {
            border-color: #0d6efd;
            color: #0d6efd;
            box-shadow: 0 0 0 8px rgba(13, 110, 253, 0.15);
        }

        .step-label {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            margin-top: 10px;
            color: #adb5bd;
        }

        .active .step-label {
            color: #0d6efd;
        }
    </style>
</head>
<body>
    <div class="result-card">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center border-bottom pb-4 mb-4">
            <div>
                <h6 class="text-muted text-uppercase fw-bold mb-1">Live Shipment Tracking</h6>
                <h2 class="fw-bold mb-0 text-dark">@Model.TrackingNumber</h2>
            </div>
            <div class="text-end">
                <span class="badge @(Model.Status == "Delivered" ? "bg-success" : "bg-primary") fs-5 px-3 py-2 shadow-sm">@Model.Status</span>
            </div>
        </div>

        <!-- Route Context -->
        <div class="row text-center mb-5">
            <div class="col-5">
                <div class="text-muted small text-uppercase fw-bold">Origin</div>
                <div class="fs-4 fw-bold text-dark">@Model.SenderCity</div>
            </div>
            <div class="col-2 d-flex align-items-center justify-content-center text-primary fs-3">
                <i class="bi bi-arrow-right-circle-fill"></i>
            </div>
            <div class="col-5">
                <div class="text-muted small text-uppercase fw-bold">Destination</div>
                <div class="fs-4 fw-bold text-dark">@Model.ReceiverCity</div>
            </div>
        </div>

        <!-- Visual Timeline -->
        <div class="timeline-wrapper d-flex justify-content-between">
            <div class="timeline-line"></div>
            <div class="timeline-progress" style="width: @(currentStep * 25)%;"></div>
            @for (int i = 0; i < labels.Length; i++)
            {
                <div class="timeline-step @(i < currentStep ? "completed" : i == currentStep ? "active" : "")">
                    <div class="step-icon"><i class="bi @icons[i]"></i></div>
                    <div class="step-label">@labels[i]</div>
                </div>
            }
        </div>

        <!-- Detailed Activity Log (Public Version) -->
        <div class="mt-5 p-4 bg-light rounded-4 border">
            <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-clock-history me-2 text-primary"></i> Journey Milestones</h5>

            @if (Model.StatusHistories != null && Model.StatusHistories.Any())
            {
                foreach (var log in Model.StatusHistories.OrderByDescending(h => h.Timestamp))
                {
                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom border-white">
                        <div>
                            <span class="fw-bold text-dark fs-6">@log.Status</span><br />
                            <small class="text-muted">Recorded by system logistics</small>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold text-dark small">@log.Timestamp.ToLocalTime().ToString("dd MMM yyyy")</div>
                            <div class="text-muted smaller">@log.Timestamp.ToLocalTime().ToString("HH:mm")</div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="text-center mt-5">
            <a href="@Url.Action("Index")" class="btn btn-outline-dark rounded-pill px-5 fw-bold shadow-sm">
                <i class="bi bi-search me-2"></i> Track Another Parcel
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>