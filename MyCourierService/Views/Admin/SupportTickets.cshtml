@using MyCourierSA.Models
@model IEnumerable<MyCourierSA.Models.SupportTicket>

@{
    Layout = null;
    ViewBag.Title = "Support Operations Center";
    string currentFilter = ViewBag.CurrentFilter ?? "Open";

    // This ensures LINQ works perfectly without the "Dynamic Dispatch" error
    var totalOpen = Model.Count(t => t.Status == "Open" || t.Status == "In Progress");
    var totalClaims = Model.Count(t => t.ShipmentId != null && t.Status != "Resolved");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier HQ</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #4361ee;
            --success: #06d6a0;
            --warning: #ffd166;
            --danger: #ef476f;
            --dark: #0f172a;
        }

        body {
            background: #f8fafc;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            min-height: 100vh;
            color: var(--dark);
        }

        .main-overlay {
            background: linear-gradient(135deg, rgba(245, 247, 250, 0.98) 0%, rgba(230, 235, 245, 0.98) 100%);
            min-height: 100vh;
            padding-bottom: 5rem;
        }

        .glass-card {
            background: white;
            border-radius: 1.5rem;
            border: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 10px 40px rgba(0,0,0,0.03);
            padding: 2rem;
            margin-bottom: 1.5rem;
        }

        .top-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 2rem 0;
        }

        .stat-card {
            border-radius: 1.25rem;
            padding: 1.5rem;
            color: white;
            position: relative;
            overflow: hidden;
            transition: 0.3s;
        }

        .bg-warning-grad {
            background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
        }

        .bg-danger-grad {
            background: linear-gradient(135deg, #f85032 0%, #e73827 100%);
        }

        .bg-success-grad {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        }

        .stat-icon {
            position: absolute;
            right: -10px;
            bottom: -10px;
            font-size: 4rem;
            opacity: 0.2;
            transform: rotate(-15deg);
        }

        .table thead th {
            background: #f8fafc;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 1.2rem 1rem;
            border: none;
        }

        .table tbody td {
            padding: 1.2rem 1rem;
            border-bottom: 1px solid #f1f5f9;
        }

        .badge-priority {
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            padding: 0.4rem 0.8rem;
            border-radius: 50rem;
            letter-spacing: 0.5px;
        }

        .filter-btn {
            border-radius: 50rem;
            font-weight: 700;
            padding: 0.6rem 1.8rem;
            transition: 0.3s;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>

    <div class="main-overlay">
        <div class="container py-2">

            <!-- NAVIGATION -->
            <nav class="top-nav">
                <a href="@Url.Action("Index", "Admin")" class="btn btn-light rounded-pill px-4 fw-bold border shadow-sm">
                    <i class="bi bi-arrow-left me-2 text-primary"></i> HQ COMMAND
                </a>
                <h3 class="fw-800 text-dark mb-0">Support <span class="text-primary">Ops Hub</span></h3>
                <button onclick="location.reload()" class="btn btn-white rounded-circle shadow-sm border"><i class="bi bi-arrow-clockwise"></i></button>
            </nav>

            <!-- KPI SUMMARY -->
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="stat-card bg-warning-grad shadow-sm">
                        <h6 class="text-uppercase small fw-bold mb-1">Active Cases</h6>
                        <h2 class="mb-0 fw-800">@totalOpen</h2>
                        <i class="bi bi-envelope-open stat-icon"></i>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card bg-danger-grad shadow-sm">
                        <h6 class="text-uppercase small fw-bold mb-1">Pending Claims</h6>
                        <h2 class="mb-0 fw-800">@totalClaims</h2>
                        <i class="bi bi-exclamation-octagon stat-icon"></i>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card bg-success-grad shadow-sm">
                        <h6 class="text-uppercase small fw-bold mb-1">Resolution Rate</h6>
                        <h2 class="mb-0 fw-800">98.4%</h2>
                        <i class="bi bi-patch-check stat-icon"></i>
                    </div>
                </div>
            </div>

            <!-- MAIN INTERFACE -->
            <div class="glass-card">
                <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">
                    <h5 class="fw-800 mb-0"><i class="bi bi-layers-half text-primary me-2"></i>Active Case Queue</h5>

                    <div class="btn-group bg-light p-1 rounded-pill shadow-sm">
                        <a href="@Url.Action("SupportTickets", new { filter = "Open" })"
                           class="btn filter-btn @(currentFilter == "Open" ? "btn-primary text-white shadow" : "btn-light text-muted")">
                            Active Tickets
                        </a>
                        <a href="@Url.Action("SupportTickets", new { filter = "Resolved" })"
                           class="btn filter-btn @(currentFilter == "Resolved" ? "btn-primary text-white shadow" : "btn-light text-muted")">
                            Archived
                        </a>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr class="border-bottom">
                                <th class="ps-3">REF ID</th>
                                <th>CUSTOMER ACCOUNT</th>
                                <th>SUBJECT & CATEGORY</th>
                                <th class="text-center">SHIPMENT LINK</th>
                                <th>STATUS</th>
                                <th class="text-end pe-3">COMMAND</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-5">
                                        <i class="bi bi-patch-check display-1 text-light mb-3 d-block"></i>
                                        <p class="text-muted fw-bold">Queue clear! No @currentFilter tickets found.</p>
                                    </td>
                                </tr>
                            }
                            @foreach (var t in Model)
                            {
                                bool isClaim = t.ShipmentId != null;

                                <tr class="ticket-row">
                                    <td class="ps-3">
                                        <span class="fw-800 text-primary font-monospace">#@t.Id.ToString("D4")</span>
                                    </td>
                                    <td>
                                        @if (t.Customer != null)
                                        {
                                            <div class="fw-bold text-dark">@t.Customer.Name @t.Customer.Surname</div>
                                            <div class="smaller text-muted">@t.Customer.Email</div>
                                        }
                                        else
                                        {
                                            <div class="text-danger fw-bold smaller">Anonymous Entity</div>
                                        }
                                    </td>
                                    <td>
                                        @if (isClaim)
                                        {
                                            <span class="badge-priority bg-danger-subtle text-danger border border-danger-subtle">CLAIM</span>
                                        }
                                        else
                                        {
                                            <span class="badge-priority bg-info-subtle text-info border border-info-subtle">INQUIRY</span>
                                        }
                                        <div class="fw-bold text-dark mt-1">@t.Subject</div>
                                    </td>
                                    <td class="text-center">
                                        @if (isClaim && t.RelatedShipment != null)
                                        {
                                            <a href="@Url.Action("Details", "Admin", new { id = t.ShipmentId })" class="badge bg-light text-primary border py-2 px-3 rounded-pill fw-bold text-decoration-none shadow-sm" style="font-size: 0.7rem;">
                                                <i class="bi bi-box-seam me-1"></i> @t.RelatedShipment.TrackingNumber
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted smaller opacity-50">N/A</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            string statusColor = t.Status == "Open" ? "text-danger" : (t.Status == "In Progress" ? "text-warning" : "text-success");
                                        }
                                        <div class="smaller fw-800 text-uppercase @statusColor">
                                            <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> @t.Status
                                        </div>
                                        <div class="smaller text-muted">Updated: @t.CreatedDate.ToString("dd MMM")</div>
                                    </td>
                                    <td class="text-end pe-3">
                                        <a href="@Url.Action("TicketDetails", new { id = t.Id })" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm btn-sm">
                                            PROCESS <i class="bi bi-chevron-right ms-1"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <footer class="text-center mt-5 text-muted small pb-4">
                Resolution Intelligence Layer | © @DateTime.Now.Year MyCourierSA
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>