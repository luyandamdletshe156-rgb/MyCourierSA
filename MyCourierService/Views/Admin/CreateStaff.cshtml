@model MyCourierSA.Models.CreateStaffViewModel
@{
    Layout = null;
    ViewBag.Title = "Onboard Personnel";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier HQ</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">

    <style>
        body {
            background: #f1f5f9 url('/Content/Images/admin-bg.jpg') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            min-height: 100vh;
        }

        .main-overlay {
            background: rgba(245, 247, 250, 0.94);
            min-height: 100vh;
            backdrop-filter: blur(10px);
            padding-bottom: 5rem;
        }

        .glass-card {
            background: white;
            border: 1px solid rgba(255, 255, 255, 0.8);
            border-radius: 1.5rem;
            padding: 3rem;
            box-shadow: 0 15px 35px rgba(0,0,0,0.05);
            max-width: 800px;
            margin: 0 auto;
        }

        .top-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            padding: 1rem 0;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .btn-premium {
            border-radius: 50rem;
            padding: 0.6rem 1.5rem;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
        }

        .form-label {
            font-weight: 700;
            color: #475569;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.5rem;
        }

        .form-control, .form-select {
            border: 2px solid #e2e8f0;
            padding: 0.75rem 1rem;
            font-weight: 600;
            border-radius: 0.75rem;
            background-color: #f8fafc;
            transition: all 0.2s;
        }

            .form-control:focus, .form-select:focus {
                background-color: #ffffff;
                border-color: #0d6efd;
                box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
                outline: none;
            }

        .btn-submit {
            background: #0d6efd;
            color: white;
            border: none;
            border-radius: 50rem;
            padding: 1rem 3rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            width: 100%;
        }

            .btn-submit:hover {
                background: #0b5ed7;
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(13, 110, 253, 0.2);
            }

        .icon-circle {
            width: 60px;
            height: 60px;
            background: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 1.5rem auto;
        }
    </style>
</head>
<body>
    <div class="main-overlay">
        <div class="container py-4">

            <!-- TOP NAVIGATION -->
            <nav class="top-nav mb-5">
                <a href="@Url.Action("Index", "Admin")" class="btn btn-light btn-premium border shadow-sm text-secondary">
                    <i class="bi bi-arrow-left me-2"></i> Return to Command
                </a>
                <h3 class="fw-bold text-dark mb-0">Staff <span class="text-primary">Onboarding</span></h3>
            </nav>

            <!-- FORM CARD -->
            <div class="glass-card position-relative overflow-hidden">

                <!-- Decorative background elements -->
                <div class="position-absolute top-0 end-0 p-4 opacity-25" style="z-index: 0;">
                    <i class="bi bi-person-badge-fill" style="font-size: 10rem; color: #e2e8f0;"></i>
                </div>

                <div class="position-relative" style="z-index: 1;">
                    <div class="icon-circle">
                        <i class="bi bi-person-plus-fill"></i>
                    </div>

                    <div class="text-center mb-5">
                        <h2 class="fw-bold text-dark">Register New Personnel</h2>
                        <p class="text-muted small">Create a secure system account for a new Dispatcher or Fleet Driver.</p>
                    </div>

                    @using (Html.BeginForm("CreateStaff", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <!-- Display any validation errors -->
                        if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger border-0 rounded-3 shadow-sm bg-danger bg-opacity-10 text-danger mb-4 px-4 py-3">
                                <h6 class="fw-bold mb-2"><i class="bi bi-exclamation-triangle-fill me-2"></i>Registration Failed</h6>
                                @Html.ValidationSummary(true, "", new { @class = "mb-0 small" })
                            </div>
                        }

                        <div class="row g-4 mb-4">
                            <!-- Role Selection -->
                            <div class="col-12">
                                <label class="form-label text-primary"><i class="bi bi-shield-lock-fill me-1"></i> Assignment Role</label>
                                @Html.DropDownList("selectedRole", (SelectList)ViewBag.Roles, "-- Select Clearance Level --", new { @class = "form-select form-select-lg border-primary border-2", required = "required" })
                            </div>

                            <div class="col-12">
                                <hr class="text-muted opacity-25 my-2" />
                            </div>

                            <!-- Personal Details -->
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                @Html.EditorFor(m => m.Name, new { htmlAttributes = new { @class = "form-control", placeholder = "e.g. John", required = "required" } })
                                @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Last Name (Surname)</label>
                                @Html.EditorFor(m => m.Surname, new { htmlAttributes = new { @class = "form-control", placeholder = "e.g. Doe", required = "required" } })
                                @Html.ValidationMessageFor(m => m.Surname, "", new { @class = "text-danger small" })
                            </div>

                            <!-- Contact Details -->
                            <div class="col-md-6">
                                <label class="form-label">Corporate Email</label>
                                @Html.EditorFor(m => m.Email, new { htmlAttributes = new { @class = "form-control", type = "email", placeholder = "john@mycourier.co.za", required = "required" } })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Mobile Number</label>
                                @Html.EditorFor(m => m.PhoneNumber, new { htmlAttributes = new { @class = "form-control", type = "tel", placeholder = "082 123 4567", required = "required" } })
                                @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger small" })
                            </div>

                            <!-- Security Details -->
                            <div class="col-md-6">
                                <label class="form-label">Temporary Password</label>
                                @Html.EditorFor(m => m.Password, new { htmlAttributes = new { @class = "form-control", type = "password", placeholder = "••••••••", required = "required" } })
                                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Confirm Password</label>
                                @Html.EditorFor(m => m.ConfirmPassword, new { htmlAttributes = new { @class = "form-control", type = "password", placeholder = "••••••••", required = "required" } })
                                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                            </div>
                        </div>

                        <div class="mt-5">
                            <button type="submit" class="btn-submit shadow-sm">
                                <i class="bi bi-shield-check me-2"></i> Issue Security Clearance & Create Account
                            </button>
                        </div>
                    }
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="text-muted small"><i class="bi bi-info-circle me-1"></i> Upon creation, the staff member can log in immediately using the provided email and temporary password.</p>
            </div>

        </div>
    </div>
</body>
</html>
