@model MyCourierSA.Models.SupportTicket
@using Microsoft.AspNet.Identity
@{
    Layout = null; // Standalone Premium View
    ViewBag.Title = "Process Ticket #" + Model.Id.ToString("D4");
    string currentUserId = User.Identity.GetUserId();
    bool isClaim = Model.ShipmentId != null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier HQ</title>

    <!-- Google Fonts & Bootstrap -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --primary: #4361ee;
            --success: #06d6a0;
            --warning: #ffd166;
            --danger: #ef476f;
            --dark: #0f172a;
        }

        body {
            background: #f8fafc;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            min-height: 100vh;
            color: var(--dark);
        }

        .main-overlay {
            background: linear-gradient(135deg, rgba(245, 247, 250, 0.98) 0%, rgba(230, 235, 245, 0.98) 100%);
            min-height: 100vh;
            padding-bottom: 3rem;
        }

        .glass-card {
            background: white;
            border: 1px solid rgba(0,0,0,0.05);
            border-radius: 1.5rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.03);
            padding: 2rem;
            margin-bottom: 1.5rem;
        }

        /* Chat Terminal Styling */
        .chat-terminal {
            height: 550px;
            overflow-y: auto;
            padding: 2rem;
            background: #fdfdfd;
            border: 1px solid #f1f5f9;
            border-radius: 1.25rem;
            scrollbar-width: thin;
        }

        .msg-group {
            margin-bottom: 2rem;
            display: flex;
            flex-direction: column;
        }

        .bubble {
            padding: 1.2rem;
            border-radius: 1.2rem;
            max-width: 80%;
            font-size: 0.95rem;
            line-height: 1.6;
            position: relative;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        }

        /* Customer: Left Aligned */
        .msg-customer {
            align-items: flex-start;
        }

            .msg-customer .bubble {
                background: #ffffff;
                color: #1e293b;
                border: 1px solid #e2e8f0;
                border-bottom-left-radius: 4px;
            }

        /* Admin: Right Aligned */
        .msg-admin {
            align-items: flex-end;
        }

            .msg-admin .bubble {
                background: var(--primary);
                color: #ffffff;
                border-bottom-right-radius: 4px;
                box-shadow: 0 10px 20px rgba(67, 97, 238, 0.15);
            }

        .meta-text {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 5px;
            opacity: 0.7;
        }

        /* Dossier Sidebar */
        .dossier-label {
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            color: #94a3b8;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }

        .dossier-value {
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 1.2rem;
        }

        .btn-premium {
            border-radius: 50rem;
            padding: 0.75rem 1.8rem;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
            transition: 0.3s;
        }

        textarea.reply-box {
            background: #f8fafc;
            border: 2px solid #f1f5f9;
            border-radius: 1rem;
            padding: 1.2rem;
            resize: none;
            transition: 0.3s;
        }

            textarea.reply-box:focus {
                background: #fff;
                border-color: var(--primary);
                box-shadow: 0 0 0 4px rgba(67, 97, 238, 0.1);
                outline: none;
            }

        .status-pill {
            font-size: 0.7rem;
            font-weight: 800;
            padding: 0.4rem 1rem;
            border-radius: 50rem;
            text-transform: uppercase;
        }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <div class="main-overlay">
        <div class="container py-4">

            <!-- TOP BAR -->
            <nav class="d-flex justify-content-between align-items-center mb-4">
                <a href="@Url.Action("SupportTickets", "Admin")" class="btn btn-light rounded-pill px-4 fw-bold border shadow-sm">
                    <i class="bi bi-arrow-left me-2 text-primary"></i> TICKET QUEUE
                </a>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted fw-bold smaller">TICKET ID: <span class="text-dark">#@Model.Id.ToString("D4")</span></span>
                    @{
                        string sClass = Model.Status == "Open" ? "bg-danger text-white" : (Model.Status == "In Progress" ? "bg-warning text-dark" : "bg-success text-white");
                    }
                    <span class="status-pill @sClass shadow-sm">@Model.Status</span>
                </div>
            </nav>

            <div class="row g-4">
                <!-- CONVERSATION TERMINAL -->
                <div class="col-lg-8">
                    <div class="glass-card mb-0">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-800 mb-0">Resolution Timeline</h5>
                            <span class="text-muted smaller"><i class="bi bi-clock-history me-1"></i> First Contact: @Model.CreatedDate.ToString("dd MMM, HH:mm")</span>
                        </div>

                        <div class="chat-terminal mb-4" id="chatBox">
                            <!-- INITIAL CUSTOMER MESSAGE -->
                            <div class="msg-group msg-customer">
                                <div class="meta-text text-primary">Initial Inquiry</div>
                                <div class="bubble">
                                    <div class="fw-800 mb-2">@Model.Customer.Name wrote:</div>
                                    @Model.InitialMessage
                                    <div class="text-end mt-2 opacity-50 smaller">@Model.CreatedDate.ToString("g")</div>
                                </div>
                            </div>

                            <!-- SUBSEQUENT REPLIES -->
                            @foreach (var reply in Model.Replies.OrderBy(r => r.CreatedDate))
                            {
                                bool isAdmin = reply.AuthorId != Model.CustomerId;
                                <div class="msg-group @(isAdmin ? "msg-admin" : "msg-customer")">
                                    <div class="meta-text @(isAdmin ? "text-primary" : "text-muted")">
                                        @(isAdmin ? "HQ Response" : "Customer Update")
                                    </div>
                                    <div class="bubble">
                                        @reply.Message
                                        <div class="text-end mt-2 opacity-50 smaller">@reply.CreatedDate.ToString("g")</div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- HQ REPLY INTERFACE -->
                        @using (Html.BeginForm("TicketReply", "Admin", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ticketId" value="@Model.Id" />

                            <div class="p-3 bg-light rounded-4 border">
                                <textarea name="message" class="form-control reply-box mb-3" rows="4" placeholder="Draft your official response..." required></textarea>

                                <div class="row g-3 align-items-center">
                                    <div class="col-md-5">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="smaller fw-bold text-muted text-uppercase">Transition:</span>
                                            <select name="newStatus" class="form-select form-select-sm rounded-pill border-0 shadow-sm fw-bold">
                                                <option value="In Progress" @(Model.Status == "In Progress" ? "selected" : "")>In Progress</option>
                                                <option value="Resolved" @(Model.Status == "Resolved" ? "selected" : "")>Resolved</option>
                                                <option value="Open" @(Model.Status == "Open" ? "selected" : "")>Open</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-7 text-end">
                                        <button type="submit" class="btn btn-premium btn-primary w-100 shadow">
                                            <i class="bi bi-send-check-fill me-2"></i> Transmit Response
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- SIDEBAR CASE DOSSIER -->
                <div class="col-lg-4">
                    <div class="glass-card">
                        <h5 class="fw-800 mb-4 border-bottom pb-3">Case Dossier</h5>

                        <div class="dossier-label">Inquiry Subject</div>
                        <div class="dossier-value fs-5 text-primary">@Model.Subject</div>

                        <div class="dossier-label">Customer Profile</div>
                        <div class="dossier-value">
                            <div class="text-dark">@Model.Customer.Name @Model.Customer.Surname</div>
                            <a href="mailto:@Model.Customer.Email" class="text-decoration-none smaller fw-600">@Model.Customer.Email</a>
                            <div class="smaller text-muted mt-1">@Model.Customer.PhoneNumber</div>
                        </div>

                        <div class="dossier-label">System Priority</div>
                        <div class="dossier-value">
                            @{
                                string pClass = Model.Priority == "High" ? "bg-danger" : "bg-primary";
                            }
                            <span class="badge @pClass rounded-pill px-3">@Model.Priority Priority</span>
                        </div>

                        @if (isClaim && Model.RelatedShipment != null)
                        {
                            <div class="mt-4 p-3 rounded-4 border-danger bg-danger bg-opacity-10 border border-opacity-20">
                                <h6 class="fw-800 text-danger mb-3"><i class="bi bi-box-seam me-2"></i>Linked Shipment</h6>

                                <div class="dossier-label text-danger">Tracking Number</div>
                                <div class="dossier-value font-monospace">#@Model.RelatedShipment.TrackingNumber</div>

                                <div class="dossier-label text-danger">Logistics Status</div>
                                <div class="dossier-value smaller text-uppercase">@Model.RelatedShipment.Status</div>

                                <a href="@Url.Action("Details", "Admin", new { id = Model.ShipmentId })" class="btn btn-sm btn-danger w-100 rounded-pill fw-bold">
                                    INVESTIGATE PARCEL
                                </a>
                            </div>
                        }
                    </div>

                    <!-- ADMIN GUIDELINES -->
                    <div class="p-4 rounded-4 bg-primary bg-opacity-10 border border-primary border-opacity-10">
                        <h6 class="fw-800 text-primary mb-3"><i class="bi bi-shield-check me-2"></i>Staff Protocol</h6>
                        <ul class="list-unstyled smaller fw-600 text-primary opacity-75 mb-0">
                            <li class="mb-2">1. Validate claim against Proof of Delivery.</li>
                            <li class="mb-2">2. Maintain professional corporate tone.</li>
                            <li>3. Resolve tickets within 24 operational hours.</li>
                        </ul>
                    </div>
                </div>
            </div>

            <footer class="text-center mt-5 text-muted small">
                Personnel Level: Administrator | Secure Communications Layer | © @DateTime.Now.Year MyCourierSA
            </footer>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Automatic scroll to newest messages
        const chatBox = document.getElementById("chatBox");
        chatBox.scrollTop = chatBox.scrollHeight;
    </script>
</body>
</html>