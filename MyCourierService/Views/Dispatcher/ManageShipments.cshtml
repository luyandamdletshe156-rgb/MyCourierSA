
@model IEnumerable<MyCourierSA.Models.Shipment>
@using MyCourierSA.Constants
@{
    Layout = null;
    ViewBag.Title = "Master Shipment Registry";
    var shipmentList = Model?.ToList() ?? new List<MyCourierSA.Models.Shipment>();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">

    <style>
        body {
            background: #f1f5f9 url('/Content/Images/admin-bg.jpg') no-repeat center center fixed;
            background-size: cover; font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0; min-height: 100vh;
        }

        .main-overlay {
            background: rgba(245, 247, 250, 0.96);
            min-height: 100vh; backdrop-filter: blur(12px); padding-bottom: 5rem;
        }

        .glass-card {
            background: white; border-radius: 1.5rem; padding: 2rem;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08); border: 1px solid rgba(0,0,0,0.05);
        }

        .top-nav {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 2rem; padding: 1.5rem 0; border-bottom: 1px solid rgba(0,0,0,0.1);
        }

        .btn-premium { border-radius: 50rem; padding: 0.6rem 1.5rem; font-weight: 700; text-transform: uppercase; font-size: 0.75rem; }

        .search-bar {
            border-radius: 50rem; padding: 0.8rem 1.8rem; border: 2px solid #e2e8f0;
            background: #fff; max-width: 500px; width: 100%; transition: 0.3s;
        }

        .search-bar:focus { border-color: #0d6efd; box-shadow: 0 0 15px rgba(13,110,253,0.1); outline: none; }

        .tracking-code { font-family: 'JetBrains Mono', monospace; font-weight: 800; color: #0d6efd; letter-spacing: -0.5px; }

        .status-badge { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; padding: 0.5rem 1rem; border-radius: 30px; }

        .table-row { transition: all 0.2s ease; border-bottom: 1px solid #f1f5f9; }
        .table-row:hover { background-color: #f8fafc; }

        .price-text { font-weight: 700; color: #10b981; font-family: 'JetBrains Mono', monospace; }
        
        @@media print { .top-nav, .search-bar, .command-col { display: none !important; } }
    </style>
</head>
<body>
    <div class="main-overlay">
        <div class="container py-3">

            <!-- NAVIGATION -->
            <nav class="top-nav">
                <a href="@Url.Action("Index", "Dispatcher")" class="btn btn-white btn-premium border shadow-sm">
                    <i class="bi bi-arrow-left me-2"></i> Dispatch HQ
                </a>
                <div class="text-center">
                    <h3 class="fw-bold text-dark mb-0">Master <span class="text-primary">Registry</span></h3>
                    <small class="text-muted text-uppercase fw-bold tracking-widest" style="font-size: 0.6rem;">Central Shipment Database</small>
                </div>
                <div class="d-flex gap-2">
                    <button onclick="window.print()" class="btn btn-dark btn-premium shadow-sm">
                        <i class="bi bi-printer me-2"></i> Export PDF
                    </button>
                </div>
            </nav>

            <div class="glass-card">
                <!-- SEARCH & STATS -->
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                    <div class="position-relative w-100" style="max-width: 500px;">
                        <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        <input type="text" id="registrySearch" class="form-control ps-5 search-bar" placeholder="Filter by tracking #, name, city or status...">
                    </div>
                    <div class="d-flex gap-3">
                        <div class="text-end">
                            <small class="text-muted fw-bold d-block text-uppercase" style="font-size: 0.6rem;">Total Records</small>
                            <span class="badge bg-primary rounded-pill">@shipmentList.Count</span>
                        </div>
                    </div>
                </div>

                <!-- MASTER TABLE -->
                <div class="table-responsive">
                    <table class="table align-middle mb-0" id="registryTable">
                        <thead>
                            <tr class="text-muted small text-uppercase fw-bold">
                                <th class="ps-4">Induction</th>
                                <th>Tracking & Type</th>
                                <th>Route & Personnel</th>
                                <th>Billing</th>
                                <th>Status</th>
                                <th class="text-end pe-4 command-col">Command</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!shipmentList.Any())
                            {
                                <tr id="noDataRow"><td colspan="6" class="text-center py-5 text-muted">No shipment records found in the database.</td></tr>
                            }
                            @foreach (var s in shipmentList)
                            {
                                <tr class="table-row">
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark small">@s.CreatedDate.ToString("dd MMM yyyy")</div>
                                        <div class="text-muted" style="font-size: 0.7rem;">@s.CreatedDate.ToString("HH:mm")</div>
                                    </td>
                                    <td>
                                        <div class="tracking-code">@s.TrackingNumber</div>
                                        <div class="text-muted small fw-bold">@s.ParcelType</div>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark small">@s.ReceiverName</div>
                                        <div class="small text-muted mb-1">@(s.SenderCity) <i class="bi bi-arrow-right mx-1"></i> @(s.ReceiverCity)</div>
                                        @if (s.AssignedDriver != null)
                                        {
                                            <span class="text-primary" style="font-size: 0.7rem;"><i class="bi bi-truck me-1"></i> @s.AssignedDriver.UserName</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="price-text">R @s.Price.ToString("N2")</div>
                                        <small class="text-muted" style="font-size: 0.65rem;">@s.DeliveryOption</small>
                                    </td>
                                    <td>
                                        <span class="badge status-badge @GetBadgeClass(s.Status)">@s.Status</span>
                                    </td>
                                    <td class="text-end pe-4 command-col">
                                        <div class="d-flex justify-content-end gap-2">
                                            <a href="@Url.Action("Details", "Dispatcher", new { id = s.Id })" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold shadow-sm">Details</a>
                                            
                                            @if (s.Status == AppConstants.ShipmentStatuses.AtWarehouse)
                                            {
                                                <a href="@Url.Action("PrintLabel", "Dispatcher", new { id = s.Id })" target="_blank" class="btn btn-sm btn-dark rounded-circle p-2 shadow-sm" title="Print Label">
                                                    <i class="bi bi-printer d-block"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                            <!-- JavaScript will toggle this if no matches found -->
                            <tr id="noResultsRow" style="display:none;"><td colspan="6" class="text-center py-5 text-muted">No shipments match your search criteria.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <footer class="text-center mt-5 text-muted small">
                <div class="mb-1 fw-bold text-uppercase" style="letter-spacing: 2px;">MyCourier SA</div>
                <i class="bi bi-shield-lock me-1"></i> Encrypted Registry Management System
            </footer>

        </div>
    </div>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Enhanced JS Filter
        document.getElementById('registrySearch').addEventListener('keyup', function () {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll('.table-row');
            let matchCount = 0;

            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                if (text.includes(filter)) {
                    row.style.display = '';
                    matchCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Show/Hide "No Results" row
            const noResults = document.getElementById('noResultsRow');
            if (noResults) {
                noResults.style.display = (matchCount === 0 && filter !== '') ? '' : 'none';
            }
        });
    </script>
</body>
</html>

@functions {
    public string GetBadgeClass(string status)
    {
        if (string.IsNullOrEmpty(status)) return "bg-light";
        if (status == AppConstants.ShipmentStatuses.Pending) return "bg-warning text-dark";
        if (status == AppConstants.ShipmentStatuses.Approved) return "bg-info text-dark";
        if (status == AppConstants.ShipmentStatuses.AtWarehouse) return "bg-success text-white";
        if (status.Contains("Assigned") || status.Contains("Transit") || status.Contains("Collection")) return "bg-primary text-white";
        if (status == AppConstants.ShipmentStatuses.Cancelled) return "bg-danger text-white";
        if (status == AppConstants.ShipmentStatuses.Delivered) return "bg-dark text-white";
        return "bg-secondary text-white";
    }
}