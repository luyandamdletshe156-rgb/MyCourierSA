@using MyCourierSA.Constants
@model MyCourierSA.Models.CreateShipmentViewModel
@{
    Layout = null;
    ViewBag.Title = "Register Direct Shipment";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Dispatch Command</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image: linear-gradient(135deg, rgba(10, 15, 30, 0.85) 0%, rgba(10, 15, 30, 0.95) 100%), url('/Content/Images/courier-bg.jpg');
            background-position: center;
            background-size: cover;
            background-attachment: fixed;
            color: #e0e0e0;
            font-family: 'Segoe UI', sans-serif;
            padding-bottom: 3rem;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(15px);
            border-radius: 1.25rem;
            padding: 2.5rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            color: #2c3e50;
            margin-top: 2rem;
        }

        .section-card {
            background: rgba(248, 249, 250, 0.7);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: 1rem;
            padding: 1.5rem;
            height: 100%;
        }

        .drop-zone {
            border: 2px dashed #0d6efd;
            border-radius: 1rem;
            background: rgba(13, 110, 253, 0.05);
            padding: 2rem;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
        }

            .drop-zone:hover {
                background: rgba(13, 110, 253, 0.1);
            }

        .preview-img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 0.5rem;
            border: 2px solid #fff;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        .price-card {
            background: linear-gradient(135deg, #198754 0%, #146c43 100%);
            color: white;
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: 0 10px 20px rgba(25, 135, 84, 0.3);
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
        }

        .modal-content.glass-modal {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 1.25rem;
            border: none;
        }

        .preview-label {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            color: #6c757d;
            margin-bottom: 0;
        }

        .preview-value {
            font-weight: 600;
            color: #212529;
            margin-bottom: 0.75rem;
        }
    </style>
</head>
<body>

    <div class="container pt-4 d-flex justify-content-between align-items-center">
        <a href="@Url.Action("Index", "Dispatcher")" class="btn btn-outline-light rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-left me-2"></i> Back to Dashboard
        </a>
        <h4 class="mb-0 fw-bold text-white"><i class="bi bi-radar text-info me-2"></i> Dispatch Command</h4>
    </div>

    <main class="container">
        <div class="glass-panel mx-auto">

            <div class="text-center mb-4">
                <span class="badge bg-success mb-2 px-3 py-2 fs-6 shadow-sm"><i class="bi bi-shield-check me-1"></i> Warehouse Induction Mode</span>
                <h2 class="fw-bolder mb-2 text-dark">Register Direct Shipment</h2>
                <p class="text-muted">Parcels logged here bypass the pickup queue and are instantly approved for routing.</p>
            </div>

            @using (Html.BeginForm("CreateShipment", "Dispatcher", FormMethod.Post, new { id = "shipmentForm", enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(false, "", new { @class = "alert alert-danger shadow-sm rounded-3" })

                <div class="row g-4">
                    <!-- 1. SENDER INFO -->
                    <div class="col-lg-6">
                        <div class="section-card">
                            <div class="section-title text-primary"><i class="bi bi-person-up fs-4 me-2"></i> Sender Details</div>
                            <div class="form-floating mb-3">
                                @Html.TextBoxFor(m => m.SenderName, new { @class = "form-control", placeholder = "Full Name", required = "required", id = "SenderName" })
                                <label>Full Name *</label>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-md-6 form-floating">
                                    @Html.TextBoxFor(m => m.SenderPhone, new { @class = "form-control", placeholder = "Phone", required = "required", id = "SenderPhone" })
                                    <label>Phone *</label>
                                </div>
                                <div class="col-md-6 form-floating">
                                    @Html.TextBoxFor(m => m.SenderEmail, new { @class = "form-control", placeholder = "Email", type = "email", required = "required" })
                                    <label>Email *</label>
                                </div>
                            </div>
                            <div class="form-floating mb-3">
                                @Html.TextAreaFor(m => m.SenderAddress, new { @class = "form-control", placeholder = "Address", required = "required", style = "height: 60px", id = "SenderAddress" })
                                <label>Street Address *</label>
                            </div>

                            <!-- ZONAL ROUTING: SENDER -->
                            <div class="row g-2 mb-0">
                                <div class="col-md-6 form-floating">
                                    <select name="SenderProvince" id="SenderProvince" class="form-select" required>
                                        <option value="" disabled selected>Select Province</option>
                                    </select>
                                    <label>Province *</label>
                                </div>
                                <div class="col-md-6 form-floating">
                                    <select name="SenderCity" id="SenderCity" class="form-select" required disabled>
                                        <option value="" disabled selected>Select City</option>
                                    </select>
                                    <label>City / Town *</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 2. RECEIVER INFO -->
                    <div class="col-lg-6">
                        <div class="section-card">
                            <div class="section-title text-success"><i class="bi bi-person-down fs-4 me-2"></i> Receiver Details</div>
                            <div class="form-floating mb-3">
                                @Html.TextBoxFor(m => m.ReceiverName, new { @class = "form-control", placeholder = "Full Name", required = "required", id = "ReceiverName" })
                                <label>Full Name *</label>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-md-6 form-floating">
                                    @Html.TextBoxFor(m => m.ReceiverPhone, new { @class = "form-control", placeholder = "Phone", required = "required", id = "ReceiverPhone" })
                                    <label>Phone *</label>
                                </div>
                                <div class="col-md-6 form-floating">
                                    @Html.TextBoxFor(m => m.ReceiverEmail, new { @class = "form-control", placeholder = "Email", type = "email" })
                                    <label>Email (Optional)</label>
                                </div>
                            </div>
                            <div class="form-floating mb-3">
                                @Html.TextAreaFor(m => m.ReceiverAddress, new { @class = "form-control", style = "height: 60px", placeholder = "Address", required = "required", id = "ReceiverAddress" })
                                <label>Street Address *</label>
                            </div>

                            <!-- ZONAL ROUTING: RECEIVER -->
                            <div class="row g-2 mb-0">
                                <div class="col-md-6 form-floating">
                                    <select name="ReceiverProvince" id="ReceiverProvince" class="form-select" required>
                                        <option value="" disabled selected>Select Province</option>
                                    </select>
                                    <label>Province *</label>
                                </div>
                                <div class="col-md-6 form-floating">
                                    <select name="ReceiverCity" id="ReceiverCity" class="form-select" required disabled>
                                        <option value="" disabled selected>Select City</option>
                                    </select>
                                    <label>City / Town *</label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 3. LOGISTICS -->
                    <div class="col-12">
                        <div class="section-card border-primary border-2">
                            <div class="row g-4 align-items-center">
                                <div class="col-md-7">
                                    <div class="section-title text-dark"><i class="bi bi-truck fs-4 me-2"></i> Parcel Specifications</div>
                                    <div class="row g-3">
                                        <div class="col-md-6 form-floating">
                                            @Html.DropDownListFor(m => m.ParcelType, Model.ParcelTypes, "Select type", new { @class = "form-select", required = "required", id = "ParcelType" })
                                            <label>Package Size *</label>
                                        </div>
                                        <div class="col-md-6 form-floating">
                                            @Html.TextBoxFor(m => m.ParcelWeight, new { @class = "form-control", placeholder = "Weight", type = "number", step = "0.1", required = "required", id = "ParcelWeight" })
                                            <label>Weight (kg) *</label>
                                        </div>
                                        <div class="col-md-6 form-floating">
                                            @Html.DropDownListFor(m => m.DeliveryOption, Model.DeliveryOptions, "Select option", new { @class = "form-select", required = "required", id = "DeliveryOption" })
                                            <label>Delivery Speed *</label>
                                        </div>
                                        <div class="col-md-6 form-floating">
                                            @Html.TextBoxFor(m => m.PickupDateTime, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local", required = "required" })
                                            <label>Induction Time *</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5">
                                    <div class="price-card text-center">
                                        <h5 class="text-uppercase fw-bold opacity-75 mb-1">Calculated Cost</h5>
                                        <h1 class="display-3 fw-bolder mb-0" id="priceEst">R 0.00</h1>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 4. ATTACHMENTS -->
                    <div class="col-12">
                        <div class="section-card">
                            <div class="section-title text-dark"><i class="bi bi-camera fs-4 me-2"></i> Parcel Photos</div>
                            <input type="file" name="ParcelFiles" id="fileInput" class="d-none" multiple accept="image/*" />
                            <div class="drop-zone" id="dropZone">
                                <i class="bi bi-cloud-arrow-up display-5 text-primary mb-2 d-block"></i>
                                <h6 class="fw-bold">Attach Induction Photos</h6>
                                <p class="text-muted small mb-0">Drag and drop or click to browse files</p>
                            </div>
                            <div class="preview-container d-flex flex-wrap gap-2 mt-3" id="previewContainer"></div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <button type="button" class="btn btn-primary btn-lg w-100 py-3 fw-bold shadow-lg" onclick="openPreviewModal()">
                        <i class="bi bi-clipboard-check me-2"></i> Review & Induct Shipment
                    </button>
                </div>
            }
        </div>
    </main>

    <!-- PREVIEW MODAL -->
    <div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content glass-modal shadow-lg">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-eye me-2"></i> Final Review</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 text-dark">
                    <div class="row">
                        <div class="col-md-6 border-end">
                            <p class="preview-label">Sender</p>
                            <p class="preview-value" id="modalSender"></p>
                            <p class="preview-label">Origin Address</p>
                            <p class="preview-value" id="modalOrigin"></p>
                        </div>
                        <div class="col-md-6 ps-md-4">
                            <p class="preview-label">Receiver</p>
                            <p class="preview-value" id="modalReceiver"></p>
                            <p class="preview-label">Destination Address</p>
                            <p class="preview-value" id="modalDest"></p>
                        </div>
                    </div>
                    <hr />
                    <div class="alert alert-success d-flex justify-content-between align-items-center mb-0 py-3">
                        <span class="fw-bold text-uppercase">Total Cost to Bill:</span>
                        <h3 class="fw-bolder mb-0" id="modalPrice"></h3>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Edit Details</button>
                    <button type="button" class="btn btn-success fw-bold px-4" onclick="submitInduction()">Induct & Print Label</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // =====================================
        // 1. ZONAL ROUTING (SA LOCATIONS)
        // =====================================
        const saLocations = {
            "Eastern Cape": ["Gqeberha (PE)", "East London", "Mthatha", "Makhanda", "Uitenhage"],
            "Free State": ["Bloemfontein", "Welkom", "Sasolburg", "Kroonstad", "Bethlehem"],
            "Gauteng": ["Johannesburg", "Pretoria", "Centurion", "Midrand", "Sandton"],
            "KwaZulu-Natal": ["Durban", "Pietermaritzburg", "Richards Bay", "Newcastle", "Port Shepstone"],
            "Limpopo": ["Polokwane", "Tzaneen", "Mokopane", "Thohoyandou", "Bela-Bela"],
            "Mpumalanga": ["Mbombela (Nelspruit)", "eMalahleni (Witbank)", "Secunda", "Middelburg", "Ermelo"],
            "North West": ["Rustenburg", "Mahikeng", "Potchefstroom", "Klerksdorp", "Brits"],
            "Northern Cape": ["Kimberley", "Upington", "Springbok", "Kuruman", "De Aar"],
            "Western Cape": ["Cape Town", "Stellenbosch", "George", "Paarl", "Worcester"]
        };

        document.addEventListener("DOMContentLoaded", function () {
            const senderProv = document.getElementById("SenderProvince");
            const senderCity = document.getElementById("SenderCity");
            const receiverProv = document.getElementById("ReceiverProvince");
            const receiverCity = document.getElementById("ReceiverCity");

            // Populate Province Dropdowns
            Object.keys(saLocations).sort().forEach(prov => {
                senderProv.add(new Option(prov, prov));
                receiverProv.add(new Option(prov, prov));
            });

            // Cascade Logic for Sender
            senderProv.addEventListener("change", function () { populateCities(this.value, senderCity); });
            // Cascade Logic for Receiver
            receiverProv.addEventListener("change", function () { populateCities(this.value, receiverCity); });

            function populateCities(selectedProvince, cityDropdown) {
                cityDropdown.innerHTML = '<option value="" disabled selected>Select City</option>';
                if (selectedProvince && saLocations[selectedProvince]) {
                    cityDropdown.disabled = false;
                    saLocations[selectedProvince].sort().forEach(city => {
                        cityDropdown.add(new Option(city, city));
                    });
                } else {
                    cityDropdown.disabled = true;
                }
            }
        });

        // =====================================
        // 2. LIVE PRICING CALCULATOR
        // =====================================
        const PRICING = {
            Base: @AppConstants.Pricing.BaseFee.ToString(System.Globalization.CultureInfo.InvariantCulture),
            PerKg: @AppConstants.Pricing.PerKgRate.ToString(System.Globalization.CultureInfo.InvariantCulture),
            Small: @AppConstants.Pricing.SizeFeeSmall.ToString(System.Globalization.CultureInfo.InvariantCulture),
            Medium: @AppConstants.Pricing.SizeFeeMedium.ToString(System.Globalization.CultureInfo.InvariantCulture),
            Large: @AppConstants.Pricing.SizeFeeLarge.ToString(System.Globalization.CultureInfo.InvariantCulture),
            Express: @AppConstants.DeliveryOptions.MultiplierExpress.ToString(System.Globalization.CultureInfo.InvariantCulture),
            Overnight: @AppConstants.DeliveryOptions.MultiplierOvernight.ToString(System.Globalization.CultureInfo.InvariantCulture)
        };

        function calculatePrice() {
            let weight = parseFloat(document.getElementById('ParcelWeight').value) || 0;
            let type = document.getElementById('ParcelType').value;
            let speed = document.getElementById('DeliveryOption').value;

            let sizeFee = (type === "@AppConstants.ParcelTypes.Small") ? PRICING.Small : (type === "@AppConstants.ParcelTypes.Medium") ? PRICING.Medium : (type === "@AppConstants.ParcelTypes.Large") ? PRICING.Large : 0;
            let mult = (speed === "@AppConstants.DeliveryOptions.Express") ? PRICING.Express : (speed === "@AppConstants.DeliveryOptions.Overnight") ? PRICING.Overnight : 1.0;

            let total = (PRICING.Base + (weight * PRICING.PerKg) + sizeFee) * mult;
            document.getElementById('priceEst').innerText = "R " + total.toFixed(2);
        }

        ['ParcelWeight', 'ParcelType', 'DeliveryOption'].forEach(id => {
            document.getElementById(id).addEventListener('input', calculatePrice);
        });

        // =====================================
        // 3. MODAL LOGIC
        // =====================================
        function openPreviewModal() {
            const form = document.getElementById('shipmentForm');
            if (!form.checkValidity()) { form.reportValidity(); return; }

            document.getElementById('modalSender').innerText = document.getElementById('SenderName').value;
            document.getElementById('modalReceiver').innerText = document.getElementById('ReceiverName').value;
            document.getElementById('modalOrigin').innerText = `${document.getElementById('SenderAddress').value}, ${document.getElementById('SenderCity').value}`;
            document.getElementById('modalDest').innerText = `${document.getElementById('ReceiverAddress').value}, ${document.getElementById('ReceiverCity').value}`;
            document.getElementById('modalPrice').innerText = document.getElementById('priceEst').innerText;

            new bootstrap.Modal(document.getElementById('previewModal')).show();
        }

        function submitInduction() {
            const btn = event.target;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Inducting...';
            document.getElementById('shipmentForm').submit();
        }

        // =====================================
        // 4. FILE UPLOAD LOGIC
        // =====================================
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        dropZone.onclick = () => fileInput.click();
        fileInput.onchange = () => {
            const container = document.getElementById('previewContainer');
            container.innerHTML = '';
            [...fileInput.files].forEach(file => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = document.createElement('img');
                    img.src = e.target.result; img.className = 'preview-img';
                    container.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        };
    </script>
</body>
</html>