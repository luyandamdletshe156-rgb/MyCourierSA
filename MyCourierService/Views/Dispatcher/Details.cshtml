
@model MyCourierSA.Models.Shipment
@using MyCourierSA.Constants
@{
    Layout = null;
    ViewBag.Title = "Shipment Details - " + Model.TrackingNumber;

    // Map the expanded lifecycle to 5 clean visual steps for the UI timeline
    int currentStep = 0;
    string status = Model.Status;

    if (status == AppConstants.ShipmentStatuses.Pending || status == AppConstants.ShipmentStatuses.Approved) { currentStep = 0; }
    else if (status == AppConstants.ShipmentStatuses.AssignedForPickup || status == AppConstants.ShipmentStatuses.Collected) { currentStep = 1; }
    else if (status == AppConstants.ShipmentStatuses.AtWarehouse) { currentStep = 2; }
    else if (status == AppConstants.ShipmentStatuses.AssignedForDelivery || status == AppConstants.ShipmentStatuses.InTransit) { currentStep = 3; }
    else if (status == AppConstants.ShipmentStatuses.Delivered) { currentStep = 4; }

    string[] visualSteps = { "Order Placed", "Collection", "Warehouse", "In Transit", "Delivered" };
    string[] icons = { "bi-receipt", "bi-box-arrow-up", "bi-building", "bi-truck", "bi-box-seam-fill" };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Dispatch Command</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        body {
            background-image: linear-gradient(135deg, rgba(10, 15, 30, 0.85) 0%, rgba(10, 15, 30, 0.95) 100%), url('/Content/Images/courier-bg.jpg');
            background-position: center;
            background-size: cover;
            background-attachment: fixed;
            font-family: 'Segoe UI', sans-serif;
            padding-bottom: 3rem;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(15px);
            border-radius: 1.25rem;
            padding: 2.5rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            color: #2c3e50;
        }

        .inner-card {
            background: rgba(248, 249, 250, 0.8);
            border: 1px solid rgba(0, 0, 0, 0.05);
            border-radius: 1rem;
            padding: 1.5rem;
            height: 100%;
        }

        .info-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #6c757d;
            font-weight: 700;
            margin-bottom: 0.2rem;
        }

        .info-value {
            font-size: 1.1rem;
            font-weight: 600;
            color: #212529;
            margin-bottom: 1.2rem;
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 2px solid #e9ecef;
            padding-bottom: 0.5rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        /* Timeline Styles */
        .timeline-wrapper {
            position: relative;
            padding: 2rem 0;
            display: flex;
            justify-content: space-between;
        }

        .timeline-line {
            position: absolute;
            top: 50%;
            left: 5%;
            right: 5%;
            height: 4px;
            background-color: #e9ecef;
            transform: translateY(-50%);
            z-index: 1;
        }

        .timeline-progress {
            position: absolute;
            top: 50%;
            left: 5%;
            height: 4px;
            background-color: #0d6efd;
            transform: translateY(-50%);
            z-index: 2;
            transition: width 0.5s ease;
        }

        .timeline-step {
            position: relative;
            z-index: 3;
            text-align: center;
            width: 20%;
        }

        .step-icon {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background-color: #fff;
            border: 4px solid #e9ecef;
            color: #adb5bd;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
        }

        .step-label {
            font-size: 0.7rem;
            font-weight: 700;
            color: #adb5bd;
            margin-top: 0.5rem;
            text-transform: uppercase;
        }

        .timeline-step.completed .step-icon {
            border-color: #0d6efd;
            background-color: #0d6efd;
            color: #fff;
        }

        .timeline-step.active .step-icon {
            border-color: #0d6efd;
            color: #0d6efd;
            box-shadow: 0 0 0 5px rgba(13, 110, 253, 0.2);
        }

        .timeline-step.completed .step-label, .timeline-step.active .step-label {
            color: #212529;
        }

        .history-timeline {
            border-left: 2px solid #dee2e6;
            margin-left: 1rem;
            padding-left: 1.5rem;
            position: relative;
        }

        .history-item {
            position: relative;
            margin-bottom: 1.5rem;
        }

            .history-item::before {
                content: '';
                position: absolute;
                left: -1.95rem;
                top: 5px;
                width: 12px;
                height: 12px;
                border-radius: 50%;
                background: #0d6efd;
                border: 2px solid #fff;
            }

        .file-thumbnail {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 0.5rem;
        }

        @@media print {
            .d-print-none {
                display: none !important;
            }

            .glass-panel {
                box-shadow: none;
                border: 1px solid #ddd;
            }
        }
    </style>
</head>
<body>

    <!-- HEADER ACTION BAR -->
    <div class="container pt-4 pb-3 d-print-none d-flex flex-wrap justify-content-between align-items-center">
        <a href="@Url.Action("Index")" class="btn btn-outline-light rounded-pill px-4 fw-bold">
            <i class="bi bi-arrow-left me-2"></i> Back to Dashboard
        </a>
        <div class="d-flex gap-2">
            <button onclick="window.print()" class="btn btn-light rounded-pill px-4 fw-bold"><i class="bi bi-printer me-2"></i> Print Dossier</button>
            @if (Model.Status == AppConstants.ShipmentStatuses.AtWarehouse)
            {
                <a href="@Url.Action("PrintLabel", new { id = Model.Id })" target="_blank" class="btn btn-warning rounded-pill px-4 fw-bold">Print Label</a>
            }
        </div>
    </div>

    <main class="container">
        <div class="glass-panel mx-auto">

            <!-- HEADER -->
            <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                <div>
                    <h1 class="h3 fw-bold mb-0 text-primary">@Model.TrackingNumber</h1>
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 rounded-pill">@Model.Status</span>
                </div>
                <div class="text-end">
                    <div class="info-label">Induction Date</div>
                    <div class="fw-bold">@Model.CreatedDate.ToString("f")</div>
                </div>
            </div>

            <!-- VISUAL TRACKING TIMELINE -->
            <div class="inner-card mb-4 bg-white shadow-sm">
                <div class="timeline-wrapper">
                    <div class="timeline-line"></div>
                    <div class="timeline-progress" style="width: @(currentStep * 25)%"></div>

                    @for (int i = 0; i < visualSteps.Length; i++)
                    {
                        var stepStatus = i < currentStep ? "completed" : (i == currentStep ? "active" : "");
                        <div class="timeline-step @stepStatus">
                            <div class="step-icon">
                                @if (i < currentStep)
                                {<i class="bi bi-check-lg"></i> }
                                else
                                { <i class="bi @icons[i]"></i>}
                            </div>
                            <div class="step-label">@visualSteps[i]</div>
                        </div>
                    }
                </div>
            </div>

            <div class="row g-4">
                <!-- LEFT COLUMN: ROUTING & HISTORY -->
                <div class="col-lg-7">
                    <!-- Route Information -->
                    <div class="inner-card mb-4">
                        <div class="section-title text-primary"><i class="bi bi-geo-alt-fill me-2"></i> Route Information</div>
                        <div class="row">
                            <div class="col-md-6 border-end">
                                <div class="info-label">Sender (Origin)</div>
                                <div class="info-value">
                                    @Model.SenderName<br />
                                    <small class="text-muted fw-normal">@Model.SenderAddress, @Model.SenderCity, @Model.SenderProvince</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-label">Receiver (Destination)</div>
                                <div class="info-value">
                                    @Model.ReceiverName<br />
                                    <small class="text-muted fw-normal">@Model.ReceiverAddress, @Model.ReceiverCity, @Model.ReceiverProvince</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Warehouse Information -->
                    <div class="inner-card mb-4">
                        <div class="section-title text-warning"><i class="bi bi-archive-fill me-2"></i> Warehouse Log</div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-label">Condition upon arrival</div>
                                <div class="info-value">@(Model.Condition ?? "Awaiting processing")</div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-label">Sorting Bin</div>
                                <div class="info-value">
                                    @if (!string.IsNullOrEmpty(Model.SortingBin))
                                    {
                                        <span class="badge bg-dark font-monospace fs-6">@Model.SortingBin</span>
                                    }
                                    else
                                    { <span>Not assigned</span>}
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tracking History Log -->
                    <div class="inner-card d-print-none">
                        <div class="section-title text-secondary"><i class="bi bi-clock-history me-2"></i> Audit Trail</div>
                        <div class="history-timeline">
                            @foreach (var h in Model.StatusHistories.OrderByDescending(x => x.Timestamp))
                            {
                                <div class="history-item">
                                    <div class="history-date">@h.Timestamp.ToString("dd MMM, HH:mm")</div>
                                    <div class="history-status">@h.Status</div>
                                    <div class="history-notes">@h.Notes</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- RIGHT COLUMN: PARCEL SPECS, DRIVER & FILES -->
                <div class="col-lg-5">
                    <div class="inner-card mb-4">
                        <div class="section-title text-dark"><i class="bi bi-box me-2"></i> Specifications</div>
                        <div class="row">
                            <div class="col-6"><div class="info-label">Type</div><div class="info-value">@Model.ParcelType</div></div>
                            <div class="col-6"><div class="info-label">Weight</div><div class="info-value">@Model.ParcelWeight kg</div></div>
                            <div class="col-6"><div class="info-label">Option</div><div class="info-value">@Model.DeliveryOption</div></div>
                            <div class="col-6"><div class="info-label">Price</div><div class="info-value text-success">R @Model.Price.ToString("N2")</div></div>
                        </div>
                    </div>

                    <!-- Courier Assignment -->
                    <div class="inner-card mb-4">
                        <div class="section-title text-success"><i class="bi bi-truck me-2"></i> Assigned Courier</div>
                        @if (Model.AssignedDriver != null)
                        {
                            <div class="info-value">@Model.AssignedDriver.Name @Model.AssignedDriver.Surname</div>
                            <div class="info-label">Contact</div>
                            <div class="info-value">@Model.AssignedDriver.PhoneNumber</div>
                        }
                        else
                        {
                            <div class="text-muted fst-italic py-2">No courier assigned yet.</div>
                        }
                    </div>

                    <!-- Attached Files -->
                    <div class="inner-card d-print-none">
                        <div class="section-title text-secondary"><i class="bi bi-paperclip me-2"></i> Documents</div>
                        @if (Model.ShipmentFiles != null && Model.ShipmentFiles.Any())
                        {
                            foreach (var file in Model.ShipmentFiles)
                            {
                                <div class="d-flex align-items-center mb-3 p-2 border rounded">
                                    <i class="bi bi-file-earmark-pdf fs-3 me-3 text-danger"></i>
                                    <div class="flex-grow-1 small fw-bold">@file.FileName</div>
                                    <a href="@Url.Action("DownloadFile", new { fileId = file.Id })" class="btn btn-sm btn-outline-primary"><i class="bi bi-download"></i></a>
                                </div>
                            }
                        }
                        else
                        { <div class="text-muted fst-italic small">No attachments.</div>}
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>