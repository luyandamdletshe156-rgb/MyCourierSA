@model MyCourierSA.Models.Shipment
@{
    Layout = null;
    ViewBag.Title = "Live Parcel Journey";

    int currentStep = -1;
    double progressPercent = 0;

    if (Model != null)
    {
        // Logic to determine visual progress
        if (Model.Status == "Pending" || Model.Status == "Approved") { currentStep = 0; progressPercent = 10; }
        else if (Model.Status == "Assigned for Collection" || Model.Status == "Collected") { currentStep = 1; progressPercent = 30; }
        else if (Model.Status == "At Warehouse") { currentStep = 2; progressPercent = 60; }
        else if (Model.Status == "Assigned for Delivery" || Model.Status == "In Transit") { currentStep = 3; progressPercent = 85; }
        else if (Model.Status == "Delivered") { currentStep = 4; progressPercent = 100; }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background: linear-gradient(rgba(10, 15, 30, 0.9), rgba(10, 15, 30, 0.95)), url('/Content/Images/courier-bg.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: #e0e0e0;
            font-family: 'Segoe UI', sans-serif;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            border-radius: 1.25rem;
            padding: 2rem;
            color: #2c3e50;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        .search-box {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 1.25rem;
            padding: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            margin-bottom: 2rem;
        }

        .tracking-input {
            border-radius: 50px;
            padding: 0.8rem 2rem;
            font-size: 1.2rem;
            border: none;
        }

        /* Timeline Styling */
        .track-line {
            position: relative;
            list-style: none;
            padding: 0;
            margin: 2rem 0;
        }

            .track-line::before {
                content: '';
                position: absolute;
                left: 20px;
                top: 0;
                bottom: 0;
                width: 4px;
                background: #e9ecef;
                border-radius: 4px;
            }

        .track-item {
            position: relative;
            padding-left: 4rem;
            margin-bottom: 2.5rem;
        }

        .track-icon {
            position: absolute;
            left: 0;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #fff;
            border: 4px solid #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2;
            font-size: 1.2rem;
        }

        .track-item.completed .track-icon {
            background: #198754;
            border-color: #198754;
            color: white;
        }

        .track-item.completed::after {
            content: '';
            position: absolute;
            left: 20px;
            top: 44px;
            bottom: -40px;
            width: 4px;
            background: #198754;
            z-index: 1;
        }

        .track-item.active .track-icon {
            background: #0d6efd;
            border-color: #fff;
            color: white;
            animation: pulse-blue 2s infinite;
        }

        @@keyframes pulse-blue {
            0% {
                box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.7);
            }

            70% {
                box-shadow: 0 0 0 15px rgba(13, 110, 253, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(13, 110, 253, 0);
            }
        }

        .track-content {
            padding: 1.2rem;
            background: #fff;
            border-radius: 1rem;
            border: 1px solid #eee;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .log-item {
            padding: 8px 12px;
            border-radius: 8px;
            margin-bottom: 8px;
            border-left: 4px solid #dee2e6;
            background: #fdfdfd;
        }

        .log-Approved {
            border-left-color: #198754;
            background: #f0fff4;
        }

        .log-Assigned {
            border-left-color: #0d6efd;
            background: #f0f7ff;
        }

        .log-Warehouse {
            border-left-color: #ffc107;
            background: #fffdf0;
        }

        .fade-in {
            animation: fadeIn 0.5s ease-in forwards;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a href="@Url.Action("Index", "Dispatcher")" class="btn btn-outline-light rounded-pill px-4">
                <i class="bi bi-arrow-left me-2"></i> Back to Dashboard
            </a>
            <h4 class="mb-0 fw-bold"><i class="bi bi-radar text-info me-2"></i> Journey Tracking</h4>
        </div>

        <div class="search-box text-center mx-auto" style="max-width: 800px;">
            <h2 class="text-white fw-bold mb-4">Live Tracking Portal</h2>
            <form method="get" action="@Url.Action("TrackShipment", "Dispatcher")" class="row g-2 justify-content-center">
                <div class="col-md-8">
                    <input type="text" name="trackingNumber" value="@Request.QueryString["trackingNumber"]"
                           class="form-control tracking-input shadow-lg" placeholder="Enter Tracking Number (e.g. MC12345)" required />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-info w-100 h-100 rounded-pill fw-bold text-dark">
                        <i class="bi bi-search me-2"></i> SEARCH
                    </button>
                </div>
            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-4 rounded-4 shadow-sm border-0 fade-in">
                    <i class="bi bi-exclamation-octagon-fill me-2"></i> @ViewBag.Error
                </div>
            }
        </div>

        @if (Model != null)
        {
            <!-- PROGRESS BAR -->
            <div class="mx-auto mb-4 fade-in" style="max-width: 900px;">
                <div class="d-flex justify-content-between mb-2 px-2">
                    <span class="text-light small fw-bold text-uppercase">Shipment Status: @Model.Status</span>
                    <span class="text-info small fw-bold">@progressPercent% Complete</span>
                </div>
                <div class="progress" style="height: 10px; border-radius: 20px; background: rgba(255,255,255,0.1);">
                    <div class="progress-bar bg-info progress-bar-striped progress-bar-animated" style="width: @progressPercent%"></div>
                </div>
            </div>

            <div class="row g-4 fade-in">
                <!-- LEFT PANEL: DETAILS -->
                <div class="col-lg-4">
                    <div class="glass-panel h-100">
                        <div class="text-center mb-4 border-bottom pb-3">
                            <div class="small text-muted text-uppercase fw-bold">Tracking #</div>
                            <h3 class="fw-bold text-primary">@Model.TrackingNumber</h3>
                        </div>

                        <div class="mb-4">
                            <label class="small text-muted text-uppercase fw-bold">Routing</label>
                            <div class="fs-5 fw-bold text-dark">
                                @Model.SenderCity <i class="bi bi-arrow-right text-primary"></i> @Model.ReceiverCity
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="small text-muted text-uppercase fw-bold">Receiver</label>
                            <div class="fw-bold text-dark">@Model.ReceiverName</div>
                            <div class="small text-muted"><i class="bi bi-geo-alt-fill text-danger"></i> @Model.ReceiverAddress</div>
                        </div>

                        @if (Model.AssignedDriver != null)
                        {
                            <div class="alert alert-info border-0 shadow-sm">
                                <div class="small text-uppercase fw-bold opacity-75">Assigned Courier</div>
                                <div class="fw-bold"><i class="bi bi-person-badge me-2"></i>@Model.AssignedDriver.UserName</div>
                            </div>
                        }
                    </div>
                </div>

                <!-- RIGHT PANEL: TIMELINE -->
                <div class="col-lg-8">
                    <div class="glass-panel h-100">
                        <h4 class="fw-bold text-dark mb-4 border-bottom pb-2">Tracking Timeline</h4>

                        <div class="track-line">
                            <div class="track-item @(currentStep > 0 ? "completed" : (currentStep == 0 ? "active" : ""))">
                                <div class="track-icon"><i class="bi bi-receipt"></i></div>
                                <div class="track-content">
                                    <h6 class="fw-bold mb-1">Order Logged</h6>
                                    <p class="text-muted small mb-0">Booked on @Model.CreatedDate.ToString("dd MMM, HH:mm")</p>
                                </div>
                            </div>

                            <div class="track-item @(currentStep > 1 ? "completed" : (currentStep == 1 ? "active" : ""))">
                                <div class="track-icon"><i class="bi bi-box-arrow-in-up"></i></div>
                                <div class="track-content">
                                    <h6 class="fw-bold mb-1">Pickup & Collection</h6>
                                    <p class="text-muted small mb-0">Handled by @(Model.AssignedDriver?.UserName ?? "TBA")</p>
                                </div>
                            </div>

                            <div class="track-item @(currentStep > 2 ? "completed" : (currentStep == 2 ? "active" : ""))">
                                <div class="track-icon"><i class="bi bi-building"></i></div>
                                <div class="track-content">
                                    <h6 class="fw-bold mb-1">Warehouse Sorting</h6>
                                    <p class="text-muted small mb-0">Current Bin: @(Model.SortingBin ?? "Awaiting Sorting")</p>
                                </div>
                            </div>

                            <div class="track-item @(currentStep > 3 ? "completed" : (currentStep == 3 ? "active" : ""))">
                                <div class="track-icon"><i class="bi bi-truck"></i></div>
                                <div class="track-content">
                                    <h6 class="fw-bold mb-1">In Transit</h6>
                                    <p class="text-muted small mb-0">Parcel is en route to @Model.ReceiverCity.</p>
                                </div>
                            </div>

                            <div class="track-item @(currentStep == 4 ? "completed" : "")">
                                <div class="track-icon"><i class="bi bi-house-check"></i></div>
                                <div class="track-content">
                                    <h6 class="fw-bold mb-1">Delivered</h6>
                                    @if (Model.ActualDeliveryDate.HasValue)
                                    {
                                        <p class="text-success small fw-bold mb-0">@Model.ActualDeliveryDate.Value.ToString("dd MMM, HH:mm")</p>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- COMMAND LOG -->
                        <div class="mt-5 pt-4 border-top">
                            <h5 class="fw-bold text-muted mb-3">Internal Audit Log</h5>
                            @if (Model.StatusHistories != null)
                            {
                                foreach (var log in Model.StatusHistories.OrderByDescending(h => h.Timestamp))
                                {
                                    string logClass = log.Status.Contains("Approved") ? "log-Approved" : log.Status.Contains("Assigned") ? "log-Assigned" : log.Status.Contains("Warehouse") ? "log-Warehouse" : "";
                                    <div class="log-item @logClass">
                                        <div class="d-flex justify-content-between">
                                            <strong>@log.Status</strong>
                                            <span class="text-muted small">@log.Timestamp.ToLocalTime().ToString("HH:mm")</span>
                                        </div>
                                        <div class="text-muted small">@log.Notes</div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</body>
</html>