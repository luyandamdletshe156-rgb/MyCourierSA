@model MyCourierSA.Models.RoutePlannerDashboardViewModel
@{
    Layout = null;
    ViewBag.Title = "Route Planner & Dispatch";

    // Calculate totals from both lists
    int totalParcels = Model.InnerCityBatches.Sum(m => m.TotalParcels) + Model.OuterCityBatches.Sum(m => m.TotalParcels);
    int totalRoutes = Model.InnerCityBatches.Count + Model.OuterCityBatches.Count;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Dispatch Command</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        /* FULL SCREEN BACKGROUND */
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image: linear-gradient(135deg, rgba(10, 15, 30, 0.85) 0%, rgba(10, 15, 30, 0.95) 100%), url('/Content/Images/courier-bg.jpg');
            background-position: center;
            background-size: cover;
            background-attachment: fixed;
            color: #e0e0e0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding-bottom: 3rem;
        }

        /* GLASSMORPHISM PANELS */
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(15px);
            border-radius: 1.25rem;
            padding: 2.5rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            color: #2c3e50;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        /* CUSTOM ACCORDION STYLING */
        .accordion-item {
            background: rgba(255, 255, 255, 0.7);
            border: 1px solid rgba(0,0,0,0.1);
            border-radius: 1rem !important;
            margin-bottom: 1rem;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        .accordion-button {
            background: rgba(248, 249, 250, 0.9);
            font-weight: 700;
            color: #2c3e50;
            padding: 1.25rem 1.5rem;
            box-shadow: none !important;
        }

            .accordion-button:not(.collapsed) {
                background: #e7f1ff;
                color: #0c63e4;
                border-bottom: 1px solid rgba(0,0,0,0.05);
            }

        .accordion-body {
            background: #fff;
            padding: 1.5rem;
        }

        /* ROUTE BADGES */
        .route-badge {
            font-size: 0.9rem;
            padding: 0.5em 1em;
            border-radius: 30px;
        }

        .table-compact th {
            font-size: 0.8rem;
            text-transform: uppercase;
            color: #6c757d;
            letter-spacing: 0.5px;
            background-color: #f8f9fa;
        }

        .table-compact td {
            vertical-align: middle;
            font-size: 0.95rem;
        }

        /* ASSIGNMENT BOX */
        .assignment-box {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border: 1px dashed #adb5bd;
            border-radius: 0.75rem;
            padding: 1.5rem;
        }

        .bin-badge {
            font-family: monospace;
            font-size: 1.1rem;
            letter-spacing: 1px;
            border: 2px dashed #0d6efd;
            background-color: #e7f1ff;
            color: #0d6efd;
        }
    </style>
</head>
<body>

    <!-- HEADER NAVIGATION -->
    <div class="container pt-4 pb-4 d-flex flex-wrap justify-content-between align-items-center">
        <div>
            <a href="@Url.Action("Index", "Dispatcher")" class="btn btn-outline-light rounded-pill px-4 shadow-sm mb-2 mb-md-0">
                <i class="bi bi-arrow-left me-2"></i> Back to Dashboard
            </a>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="text-end d-none d-sm-block">
                <div class="text-light opacity-75 small text-uppercase fw-bold">Parcels Awaiting Dispatch</div>
                <h4 class="mb-0 text-warning fw-bolder">@totalParcels Parcels</h4>
            </div>
            <div class="text-end d-none d-sm-block border-start border-secondary ps-3">
                <div class="text-light opacity-75 small text-uppercase fw-bold">Active Delivery Zones</div>
                <h4 class="mb-0 text-info fw-bolder">@totalRoutes Routes</h4>
            </div>
        </div>
    </div>

    <main class="container">
        <!-- ALERTS -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-lg fw-bold" role="alert">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null || TempData["Warning"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-lg fw-bold" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i> @(TempData["Error"] ?? TempData["Warning"])
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="glass-panel mx-auto mb-5">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                <div>
                    <h2 class="mb-1 fw-bold text-dark"><i class="bi bi-map-fill text-primary me-2"></i> Smart Route Planner</h2>
                    <p class="text-muted mb-0">Grouped warehouse inventory ready for final delivery batch assignment.</p>
                </div>
            </div>

            @if (totalRoutes == 0)
            {
                <div class="text-center py-5">
                    <i class="bi bi-box2-heart text-muted" style="font-size: 5rem; opacity: 0.5;"></i>
                    <h3 class="fw-bold mt-3 text-secondary">Warehouse is Clear</h3>
                    <p class="text-muted">There are currently no sorted parcels waiting for delivery assignment.</p>
                    <a href="@Url.Action("Index", "Dispatcher")" class="btn btn-primary mt-3 px-4 rounded-pill">Return to Dashboard</a>
                </div>
            }
            else
            {
                <div class="row g-4">

                    <!-- LEFT COLUMN: INNER-CITY (FAST TRACK) -->
                    <div class="col-lg-6 border-end">
                        <h4 class="text-success fw-bold mb-3"><i class="bi bi-lightning-charge-fill"></i> Inner-City (Fast Track)</h4>
                        <p class="text-muted small">Sender and Receiver are in the same city. Prioritize these dispatches.</p>

                        @if (!Model.InnerCityBatches.Any())
                        {
                            <div class="alert alert-light border border-success border-opacity-25 text-success">No inner-city parcels pending.</div>
                        }

                        <div class="accordion" id="innerAccordion">
                            @{ int innerIdx = 0; }
                            @foreach (var route in Model.InnerCityBatches)
                            {
                                string collapseId = "collapse_inner_" + innerIdx;
                                string headingId = "heading_inner_" + innerIdx;
                                bool isExpanded = innerIdx == 0;

                                <div class="accordion-item border-success border-opacity-50">
                                    <h2 class="accordion-header" id="@headingId">
                                        <button class="accordion-button @(isExpanded ? "" : "collapsed")" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="@(isExpanded ? "true" : "false")" aria-controls="@collapseId">
                                            <div class="d-flex justify-content-between align-items-center w-100 pe-3">
                                                <div>
                                                    <i class="bi bi-geo-alt-fill text-success me-2"></i>
                                                    <span class="fs-5 fw-bold">@route.City</span>
                                                </div>
                                                <div>
                                                    <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm">
                                                        @route.TotalParcels Parcel@(route.TotalParcels > 1 ? "s" : "")
                                                    </span>
                                                </div>
                                            </div>
                                        </button>
                                    </h2>
                                    <div id="@collapseId" class="accordion-collapse collapse @(isExpanded ? "show" : "")" aria-labelledby="@headingId" data-bs-parent="#innerAccordion">
                                        <div class="accordion-body">

                                            <div class="d-flex justify-content-between mb-3 bg-light p-3 rounded">
                                                <div><span class="text-muted small d-block text-uppercase">Fetch From Bin</span><span class="badge bin-badge p-2">@route.SuggestedBin</span></div>
                                                <div class="text-end"><span class="text-muted small d-block text-uppercase">Total Load Weight</span><span class="fw-bold fs-5 text-dark">@route.TotalWeight kg</span></div>
                                            </div>

                                            <!-- BATCH ASSIGNMENT FORM -->
                                            <div class="assignment-box border-success border-opacity-25">
                                                @using (Html.BeginForm("AssignRouteBatch", "Dispatcher", FormMethod.Post, new { @class = "row g-2 align-items-center" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="province" value="@route.Province" />
                                                    <input type="hidden" name="city" value="@route.City" />

                                                    <div class="col-md-8">
                                                        @Html.DropDownList("driverId", Model.AvailableDrivers, "-- Select Courier --", new { @class = "form-select fw-bold border-success", required = "required", id = "driver_in_" + innerIdx })
                                                    </div>
                                                    <div class="col-md-4">
                                                        <button type="submit" class="btn btn-success w-100 fw-bold shadow-sm">Dispatch</button>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                innerIdx++;
                            }
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: OUTER-CITY (REGIONAL/NATIONAL) -->
                    <div class="col-lg-6">
                        <h4 class="text-primary fw-bold mb-3"><i class="bi bi-truck"></i> Regional / National</h4>
                        <p class="text-muted small">Standard long-distance routes grouped by destination province.</p>

                        @if (!Model.OuterCityBatches.Any())
                        {
                            <div class="alert alert-light border border-primary border-opacity-25 text-primary">No regional parcels pending.</div>
                        }

                        <div class="accordion" id="outerAccordion">
                            @{ int outerIdx = 0; }
                            @foreach (var route in Model.OuterCityBatches)
                            {
                                string collapseId = "collapse_outer_" + outerIdx;
                                string headingId = "heading_outer_" + outerIdx;

                                <div class="accordion-item border-primary border-opacity-50">
                                    <h2 class="accordion-header" id="@headingId">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                            <div class="d-flex justify-content-between align-items-center w-100 pe-3">
                                                <div>
                                                    <i class="bi bi-signpost-split-fill text-primary me-2"></i>
                                                    <span class="text-uppercase text-muted small me-2">@route.Province</span>
                                                    <i class="bi bi-caret-right-fill text-muted small me-2"></i>
                                                    <span class="fs-5 fw-bold">@route.City</span>
                                                </div>
                                                <div>
                                                    <span class="badge bg-primary rounded-pill px-3 py-2 shadow-sm">
                                                        @route.TotalParcels Parcel@(route.TotalParcels > 1 ? "s" : "")
                                                    </span>
                                                </div>
                                            </div>
                                        </button>
                                    </h2>
                                    <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#outerAccordion">
                                        <div class="accordion-body">

                                            <div class="d-flex justify-content-between mb-3 bg-light p-3 rounded">
                                                <div><span class="text-muted small d-block text-uppercase">Fetch From Bin</span><span class="badge bin-badge p-2 text-primary border-primary">@route.SuggestedBin</span></div>
                                                <div class="text-end"><span class="text-muted small d-block text-uppercase">Total Load Weight</span><span class="fw-bold fs-5 text-dark">@route.TotalWeight kg</span></div>
                                            </div>

                                            <!-- BATCH ASSIGNMENT FORM -->
                                            <div class="assignment-box border-primary border-opacity-25">
                                                @using (Html.BeginForm("AssignRouteBatch", "Dispatcher", FormMethod.Post, new { @class = "row g-2 align-items-center" }))
                                                {
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="province" value="@route.Province" />
                                                    <input type="hidden" name="city" value="@route.City" />

                                                    <div class="col-md-8">
                                                        @Html.DropDownList("driverId", Model.AvailableDrivers, "-- Select Courier --", new { @class = "form-select fw-bold border-primary", required = "required", id = "driver_out_" + outerIdx })
                                                    </div>
                                                    <div class="col-md-4">
                                                        <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">Dispatch</button>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                outerIdx++;
                            }
                        </div>
                    </div>

                </div>
            }
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>