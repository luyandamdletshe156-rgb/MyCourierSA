@using MyCourierSA.Constants
@model MyCourierSA.Models.CreateShipmentViewModel
@{
    Layout = null;
    ViewBag.Title = "Create Shipment";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image: linear-gradient(135deg, rgba(15, 30, 50, 0.85) 0%, rgba(10, 15, 25, 0.98) 100%), url('/Content/Images/shipment-bg.jpg');
            background-position: center;
            background-size: cover;
            background-attachment: fixed;
            color: #e0e0e0;
            font-family: 'Segoe UI', system-ui, sans-serif;
            padding-bottom: 3rem;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(20px);
            border-radius: 1.5rem;
            padding: 2.5rem;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6);
            color: #2c3e50;
            margin-top: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .section-card {
            background: rgba(248, 249, 250, 0.8);
            border: 1px solid rgba(0, 0, 0, 0.08);
            border-radius: 1.25rem;
            padding: 1.5rem;
            transition: all 0.3s ease;
            height: 100%;
        }

            .section-card:hover {
                background: #ffffff;
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            }

        .form-control, .form-select {
            border-radius: 0.75rem;
            border: 1px solid #dee2e6;
            padding: 0.75rem 1rem;
        }

        .price-card {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            border-radius: 1.25rem;
            padding: 2.5rem;
            box-shadow: 0 15px 30px rgba(13, 110, 253, 0.3);
            text-align: center;
        }

        .drop-zone {
            border: 2px dashed #0d6efd;
            border-radius: 1.25rem;
            background: rgba(13, 110, 253, 0.03);
            padding: 2rem;
            text-align: center;
            cursor: pointer;
        }

        .preview-image {
            width: 90px;
            height: 90px;
            object-fit: cover;
            border-radius: 0.75rem;
            border: 3px solid #fff;
            box-shadow: 0 5px 10px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>

    <div class="container pt-4 d-flex justify-content-between align-items-center">
        <a href="@Url.Action("Index", "Customer")" class="btn btn-outline-light rounded-pill px-4 shadow-sm">
            <i class="bi bi-arrow-left me-2"></i> Back to Dashboard
        </a>
        <div class="text-end text-white">
            <small class="opacity-75 d-block">Booking as</small>
            <span class="fw-bold">@User.Identity.Name</span>
        </div>
    </div>

    <main class="container">
        <div class="glass-panel mx-auto">
            <div class="text-center mb-5">
                <h2 class="fw-bolder mb-1 text-dark">New Shipment Booking</h2>
                <p class="text-muted">Fill in the details below to calculate costs and arrange collection.</p>
            </div>

            @using (Html.BeginForm("CreateShipment", "Customer", FormMethod.Post, new { id = "shipmentForm", enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(false, "", new { @class = "alert alert-danger rounded-4" })

                <div class="row g-4">
                    <!-- 1. SENDER DETAILS -->
                    <div class="col-lg-6">
                        <div class="section-card">
                            <h6 class="text-primary fw-bold mb-3"><i class="bi bi-geo-alt-fill me-2"></i>SENDER (COLLECTION)</h6>
                            <div class="form-floating mb-3">
                                @Html.TextBoxFor(m => m.SenderName, new { @class = "form-control", placeholder = "Name", required = "required", id = "SenderName" })
                                <label>Full Name / Company *</label>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6 form-floating">
                                    @Html.TextBoxFor(m => m.SenderEmail, new { @class = "form-control", type = "email", placeholder = "Email", required = "required" })
                                    <label>Sender Email *</label>
                                </div>
                                <div class="col-6 form-floating">
                                    @Html.TextBoxFor(m => m.SenderPhone, new { @class = "form-control", placeholder = "Phone", required = "required" })
                                    <label>Sender Phone *</label>
                                </div>
                            </div>

                            <!-- UPDATED SENDER ZONAL ROUTING -->
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="small fw-bold text-muted ms-2">Province</label>
                                    <select name="SenderProvince" id="SenderProvince" class="form-select" required>
                                        <option value="" disabled selected>-- Select Province --</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold text-muted ms-2">City / Town</label>
                                    <select name="SenderCity" id="SenderCity" class="form-select" required disabled>
                                        <option value="" disabled selected>-- Select City --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="form-floating">
                                @Html.TextAreaFor(m => m.SenderAddress, new { @class = "form-control", style = "height: 80px", placeholder = "Address", required = "required" })
                                <label>Full Street Address *</label>
                            </div>
                        </div>
                    </div>

                    <!-- 2. RECEIVER DETAILS -->
                    <div class="col-lg-6">
                        <div class="section-card">
                            <h6 class="text-success fw-bold mb-3"><i class="bi bi-house-door-fill me-2"></i>RECEIVER (DELIVERY)</h6>
                            <div class="form-floating mb-3">
                                @Html.TextBoxFor(m => m.ReceiverName, new { @class = "form-control", placeholder = "Name", required = "required", id = "ReceiverName" })
                                <label>Recipient Full Name *</label>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6 form-floating">
                                    @Html.TextBoxFor(m => m.ReceiverEmail, new { @class = "form-control", type = "email", placeholder = "Email", required = "required" })
                                    <label>Receiver Email *</label>
                                </div>
                                <div class="col-6 form-floating">
                                    @Html.TextBoxFor(m => m.ReceiverPhone, new { @class = "form-control", placeholder = "Phone", required = "required" })
                                    <label>Receiver Phone *</label>
                                </div>
                            </div>

                            <!-- UPDATED RECEIVER ZONAL ROUTING -->
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="small fw-bold text-muted ms-2">Province</label>
                                    <select name="ReceiverProvince" id="ReceiverProvince" class="form-select" required>
                                        <option value="" disabled selected>-- Select Province --</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold text-muted ms-2">City / Town</label>
                                    <select name="ReceiverCity" id="ReceiverCity" class="form-select" required disabled>
                                        <option value="" disabled selected>-- Select City --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="form-floating">
                                @Html.TextAreaFor(m => m.ReceiverAddress, new { @class = "form-control", style = "height: 80px", placeholder = "Address", required = "required" })
                                <label>Delivery Street Address *</label>
                            </div>
                        </div>
                    </div>

                    <!-- 3. PARCEL LOGISTICS -->
                    <div class="col-lg-7">
                        <div class="section-card">
                            <h6 class="text-dark fw-bold mb-3"><i class="bi bi-box-seam-fill me-2"></i>PARCEL SPECS</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="small fw-bold text-muted ms-2">Package Size</label>
                                    @Html.DropDownListFor(m => m.ParcelType, Model.ParcelTypes, "Select Size", new { @class = "form-select", required = "required", id = "parcelType" })
                                </div>
                                <div class="col-md-6">
                                    <label class="small fw-bold text-muted ms-2">Delivery Priority</label>
                                    @Html.DropDownListFor(m => m.DeliveryOption, Model.DeliveryOptions, "Select Speed", new { @class = "form-select", required = "required", id = "speed" })
                                </div>
                                <div class="col-md-6">
                                    <label class="small fw-bold text-muted ms-2">Weight (kg)</label>
                                    @Html.TextBoxFor(m => m.ParcelWeight, new { @class = "form-control", type = "number", step = "0.1", min = "0.1", placeholder = "0.0", required = "required", id = "weightInput" })
                                </div>
                                <div class="col-md-6">
                                    <label class="small fw-bold text-muted ms-2">Pickup Date & Time</label>
                                    @Html.TextBoxFor(m => m.PickupDateTime, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local", required = "required" })
                                </div>
                                <div class="col-12">
                                    <label class="small fw-bold text-muted ms-2">Collection Point (Office, Gate, etc.)</label>
                                    @Html.TextAreaFor(m => m.PickupAddress, new { @class = "form-control", style = "height: 60px", placeholder = "e.g. Building A reception", required = "required" })
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 4. LIVE PRICE DISPLAY -->
                    <div class="col-lg-5">
                        <div class="price-card h-100 d-flex flex-column justify-content-center">
                            <span class="text-uppercase fw-bold opacity-75 small mb-1">Estimated Cost</span>
                            <h1 class="display-3 fw-bolder mb-0" id="priceEst">R 0.00</h1>
                            <hr class="my-4 opacity-25">
                            <div class="d-flex justify-content-between small px-4 mb-2">
                                <span>Base + Weight Fee</span>
                                <span id="breakdownBase">R 0.00</span>
                            </div>
                            <div class="d-flex justify-content-between small px-4">
                                <span>Speed Multiplier</span>
                                <span id="breakdownMult">1.0x</span>
                            </div>
                        </div>
                    </div>

                    <!-- 5. ATTACHMENTS -->
                    <div class="col-12">
                        <div class="section-card">
                            <input type="file" name="ParcelFiles" id="fileInput" class="d-none" multiple accept="image/*" />
                            <div class="drop-zone" id="dropZone">
                                <i class="bi bi-cloud-arrow-up display-6 text-primary mb-2 d-block"></i>
                                <h6 class="fw-bold mb-1">Upload Parcel Photos (Optional)</h6>
                                <p class="text-muted small mb-0">Drag images here or click to browse</p>
                            </div>
                            <div class="preview-container d-flex flex-wrap gap-3 mt-3" id="previewContainer"></div>
                        </div>
                    </div>

                    <div class="col-12 text-center mt-4">
                        <button type="button" class="btn btn-primary btn-lg w-100 shadow-lg py-3" onclick="openCheckoutModal()">
                            <i class="bi bi-wallet2 me-2"></i> Review & Confirm Payment
                        </button>
                    </div>
                </div>
            }
        </div>
    </main>

    <!-- MODAL -->
    <div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-dark text-white py-3">
                    <h5 class="modal-title fw-bold">Confirm Your Booking</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="d-flex align-items-center mb-4 text-dark">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                            <i class="bi bi-cash-stack text-primary fs-3"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold" id="modalCost">R 0.00</h4>
                            <small class="text-muted">Total to be deducted from wallet</small>
                        </div>
                    </div>
                    <div class="bg-light p-3 rounded-3 mb-3 text-dark">
                        <div class="mb-2">
                            <label class="text-muted small d-block">From</label>
                            <span class="fw-bold" id="prevSender"></span> <small class="text-muted" id="prevOrigin"></small>
                        </div>
                        <div>
                            <label class="text-muted small d-block">To</label>
                            <span class="fw-bold" id="prevReceiver"></span> <small class="text-muted" id="prevDest"></small>
                        </div>
                    </div>
                    <button type="button" class="btn btn-success w-100 py-3 fw-bold shadow-sm" onclick="submitForm()">
                        AUTHORIZE PAYMENT & BOOK
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // =====================================
        // 1. ZONAL ROUTING (SA LOCATIONS)
        // =====================================
        const saLocations = {
            "Eastern Cape": ["Gqeberha (PE)", "East London", "Mthatha", "Makhanda", "Uitenhage"],
            "Free State": ["Bloemfontein", "Welkom", "Sasolburg", "Kroonstad", "Bethlehem"],
            "Gauteng": ["Johannesburg", "Pretoria", "Centurion", "Midrand", "Sandton"],
            "KwaZulu-Natal": ["Durban", "Pietermaritzburg", "Richards Bay", "Newcastle", "Port Shepstone"],
            "Limpopo": ["Polokwane", "Tzaneen", "Mokopane", "Thohoyandou", "Bela-Bela"],
            "Mpumalanga": ["Mbombela (Nelspruit)", "eMalahleni (Witbank)", "Secunda", "Middelburg", "Ermelo"],
            "North West": ["Rustenburg", "Mahikeng", "Potchefstroom", "Klerksdorp", "Brits"],
            "Northern Cape": ["Kimberley", "Upington", "Springbok", "Kuruman", "De Aar"],
            "Western Cape": ["Cape Town", "Stellenbosch", "George", "Paarl", "Worcester"]
        };

        document.addEventListener("DOMContentLoaded", function () {
            const senderProv = document.getElementById("SenderProvince");
            const senderCity = document.getElementById("SenderCity");
            const receiverProv = document.getElementById("ReceiverProvince");
            const receiverCity = document.getElementById("ReceiverCity");

            // Populate Province Dropdowns
            Object.keys(saLocations).sort().forEach(prov => {
                senderProv.add(new Option(prov, prov));
                receiverProv.add(new Option(prov, prov));
            });

            // Cascade Logic for Sender
            senderProv.addEventListener("change", function () { populateCities(this.value, senderCity); });
            // Cascade Logic for Receiver
            receiverProv.addEventListener("change", function () { populateCities(this.value, receiverCity); });

            function populateCities(selectedProvince, cityDropdown) {
                cityDropdown.innerHTML = '<option value="" disabled selected>-- Select City --</option>';
                if (selectedProvince && saLocations[selectedProvince]) {
                    cityDropdown.disabled = false;
                    saLocations[selectedProvince].sort().forEach(city => {
                        cityDropdown.add(new Option(city, city));
                    });
                } else {
                    cityDropdown.disabled = true;
                }
            }
        });

        // =====================================
        // 2. LIVE PRICING CALCULATOR
        // =====================================
        const PRICING = {
            Base: @AppConstants.Pricing.BaseFee.ToString(System.Globalization.CultureInfo.InvariantCulture),
            PerKg: @AppConstants.Pricing.PerKgRate.ToString(System.Globalization.CultureInfo.InvariantCulture),
            Small: @AppConstants.Pricing.SizeFeeSmall.ToString(System.Globalization.CultureInfo.InvariantCulture),
            Medium: @AppConstants.Pricing.SizeFeeMedium.ToString(System.Globalization.CultureInfo.InvariantCulture),
            Large: @AppConstants.Pricing.SizeFeeLarge.ToString(System.Globalization.CultureInfo.InvariantCulture),
            StandardMult: @AppConstants.DeliveryOptions.MultiplierStandard.ToString(System.Globalization.CultureInfo.InvariantCulture),
            ExpressMult: @AppConstants.DeliveryOptions.MultiplierExpress.ToString(System.Globalization.CultureInfo.InvariantCulture),
            OvernightMult: @AppConstants.DeliveryOptions.MultiplierOvernight.ToString(System.Globalization.CultureInfo.InvariantCulture)
        };

        function updatePrice() {
            let weight = parseFloat(document.getElementById('weightInput').value) || 0;
            let type = document.getElementById('parcelType').value;
            let speed = document.getElementById('speed').value;

            let sizeFee = 0;
            if(type === "@AppConstants.ParcelTypes.Small") sizeFee = PRICING.Small;
            else if(type === "@AppConstants.ParcelTypes.Medium") sizeFee = PRICING.Medium;
            else if(type === "@AppConstants.ParcelTypes.Large") sizeFee = PRICING.Large;

            let mult = PRICING.StandardMult;
            if(speed === "@AppConstants.DeliveryOptions.Express") mult = PRICING.ExpressMult;
            else if(speed === "@AppConstants.DeliveryOptions.Overnight") mult = PRICING.OvernightMult;

            let baseTotal = (PRICING.Base + (weight * PRICING.PerKg) + sizeFee);
            let finalTotal = baseTotal * mult;

            document.getElementById('priceEst').innerText = "R " + finalTotal.toFixed(2);
            document.getElementById('breakdownBase').innerText = "R " + baseTotal.toFixed(2);
            document.getElementById('breakdownMult').innerText = mult.toFixed(1) + "x";
        }

        document.addEventListener('DOMContentLoaded', () => {
            ['weightInput', 'parcelType', 'speed'].forEach(id => {
                const el = document.getElementById(id);
                el?.addEventListener('input', updatePrice);
                el?.addEventListener('change', updatePrice);
            });
            updatePrice();
        });

        // =====================================
        // 3. CHECKOUT MODAL & SUBMISSION
        // =====================================
        function openCheckoutModal() {
            const form = document.getElementById('shipmentForm');
            if (!form.checkValidity()) { form.reportValidity(); return; }

            document.getElementById('modalCost').innerText = document.getElementById('priceEst').innerText;
            document.getElementById('prevSender').innerText = document.getElementById('SenderName').value;
            document.getElementById('prevReceiver').innerText = document.getElementById('ReceiverName').value;
            document.getElementById('prevOrigin').innerText = "(" + document.getElementById('SenderCity').value + ")";
            document.getElementById('prevDest').innerText = "(" + document.getElementById('ReceiverCity').value + ")";

            new bootstrap.Modal(document.getElementById('checkoutModal')).show();
        }

        function submitForm() {
            const btn = document.querySelector('#checkoutModal .btn-success');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';
            btn.disabled = true;
            document.getElementById('shipmentForm').submit();
        }

        // =====================================
        // 4. IMAGE UPLOAD PREVIEW
        // =====================================
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        dropZone.onclick = () => fileInput.click();
        fileInput.onchange = () => {
            const container = document.getElementById('previewContainer');
            container.innerHTML = '';
            [...fileInput.files].forEach(file => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = document.createElement('img');
                    img.src = e.target.result; img.className = 'preview-image me-2 mb-2';
                    container.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        };
    </script>
</body>
</html>