@model MyCourierSA.Models.ApplicationUser
@{
    Layout = null;
    ViewBag.Title = "My Wallet";

    // Cast the ViewBag correctly to the Transaction model
    var transactions = ViewBag.TransactionHistory as IEnumerable<MyCourierSA.Models.WalletTransaction>
                       ?? new List<MyCourierSA.Models.WalletTransaction>();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image: linear-gradient(135deg, rgba(15, 30, 50, 0.85) 0%, rgba(10, 15, 25, 0.95) 100%), url('/Content/Images/shipment-bg.jpg');
            background-position: center;
            background-size: cover;
            background-attachment: fixed;
            color: #333;
            font-family: 'Segoe UI', sans-serif;
            padding-bottom: 3rem;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(20px);
            border-radius: 1.5rem;
            padding: 2.5rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
        }

        .balance-text {
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .preset-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .btn-preset {
            background: #fff;
            border: 2px solid #e9ecef;
            border-radius: 1rem;
            font-weight: 700;
            color: #495057;
            padding: 0.75rem 0;
            transition: 0.2s;
        }

            .btn-preset:hover, .btn-preset.active {
                background: #0d6efd;
                color: #fff;
                border-color: #0d6efd;
                transform: translateY(-2px);
            }

        .table-container {
            max-height: 500px;
            overflow-y: auto;
            border-radius: 1rem;
            background: #fff;
            border: 1px solid #e9ecef;
        }

        .table thead th {
            position: sticky;
            top: 0;
            background: #f8f9fa;
            z-index: 2;
            font-size: 0.75rem;
            text-transform: uppercase;
            padding: 1rem;
            border-bottom: 2px solid #dee2e6;
        }

        .fade-up {
            opacity: 0;
            transform: translateY(20px);
            animation: fadeUp 0.6s forwards;
        }

        @@keyframes fadeUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body class="pt-4 pt-md-5">

    <div class="container">
        <!-- TOP NAV -->
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 fade-up">
            <a href="@Url.Action("Index", "Customer")" class="btn btn-outline-light rounded-pill px-4 shadow-sm fw-bold">
                <i class="bi bi-arrow-left me-2"></i> Back to Dashboard
            </a>
            <h3 class="mb-0 fw-bold text-white d-flex align-items-center">
                <i class="bi bi-wallet2 text-info me-2 fs-2"></i> Payment Wallet
            </h3>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4 fade-up">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 rounded-4 shadow-sm mb-4 fade-up">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            </div>
        }

        <div class="row g-4">
            <!-- LEFT: BALANCE & TOP-UP -->
            <div class="col-lg-5 col-xl-4 fade-up" style="animation-delay: 0.1s;">
                <div class="glass-panel text-center h-100 d-flex flex-column">

                    <div class="mb-5">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-shield-check fs-1"></i>
                        </div>
                        <h6 class="text-uppercase fw-bold text-muted small mb-1">Available Balance</h6>
                        <h1 class="balance-text">R @Model.WalletBalance.ToString("N2")</h1>
                    </div>

                    <div class="bg-light p-4 rounded-4 text-start mt-auto">
                        <h6 class="text-dark fw-bold mb-3"><i class="bi bi-plus-circle-fill text-primary me-2"></i> Quick Top-Up</h6>

                        <div class="preset-grid mb-3">
                            <button type="button" class="btn btn-preset" onclick="setAmount(this, 100)">R100</button>
                            <button type="button" class="btn btn-preset" onclick="setAmount(this, 500)">R500</button>
                            <button type="button" class="btn btn-preset" onclick="setAmount(this, 1000)">R1k</button>
                        </div>

                        @using (Html.BeginForm("TopUp", "Customer", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <div class="input-group mb-3 border rounded-3 overflow-hidden bg-white">
                                <span class="input-group-text bg-white border-0 fw-bold text-muted">R</span>
                                <input type="number" name="amount" id="amtInput" class="form-control border-0 fw-bold fs-5" placeholder="Enter custom amount" step="0.01" min="1" required />
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow">
                                Proceed to Payment
                            </button>
                        }
                        <p class="text-center text-muted small mt-3 mb-0"><i class="bi bi-lock-fill"></i> Secured by MyCourierSA Gateway</p>
                    </div>
                </div>
            </div>

            <!-- RIGHT: TRANSACTION HISTORY -->
            <div class="col-lg-7 col-xl-8 fade-up" style="animation-delay: 0.2s;">
                <div class="glass-panel h-100">
                    <h4 class="fw-bold text-dark mb-4 border-bottom pb-3"><i class="bi bi-clock-history text-primary me-2"></i> Transaction Activity</h4>

                    <div class="table-container shadow-sm">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-4">Date & Time</th>
                                    <th>Description</th>
                                    <th class="text-end pe-4">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (transactions.Any())
                                {
                                    foreach (var t in transactions)
                                    {
                                        // LOGIC: Red for payments (negative), Green for deposits/refunds (positive)
                                        bool isNegative = t.Amount < 0;
                                        string icon = isNegative ? "bi-dash-circle-fill" : "bi-plus-circle-fill";
                                        string colorClass = isNegative ? "text-danger" : "text-success";
                                        string prefix = isNegative ? "-" : "+";

                                        <tr>
                                            <td class="ps-4">
                                                <div class="fw-bold small">@t.Timestamp.ToString("dd MMM yyyy")</div>
                                                <div class="text-muted" style="font-size: 0.7rem;">@t.Timestamp.ToString("HH:mm")</div>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="bi @icon @colorClass fs-5 me-3"></i>
                                                    <div>
                                                        <div class="fw-bold small text-dark">@t.Description</div>
                                                        <div class="text-muted" style="font-size: 0.7rem;">Reference: @t.TransactionType</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-end pe-4">
                                                <span class="fw-bold @colorClass">@prefix R @Math.Abs(t.Amount).ToString("N2")</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted">
                                            <i class="bi bi-inbox fs-1 d-block mb-2 opacity-25"></i>
                                            No transactions yet.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function setAmount(btn, val) {
            document.querySelectorAll('.btn-preset').forEach(b => b.classList.remove('active', 'btn-primary', 'text-white'));
            btn.classList.add('active', 'btn-primary', 'text-white');
            document.getElementById('amtInput').value = val;
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>