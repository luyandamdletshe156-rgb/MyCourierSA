@model MyCourierSA.Models.Shipment
@{
    Layout = null;
    ViewBag.Title = "Rate Your Delivery";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title | MyCourierSA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        body {
            background: linear-gradient(135deg, rgba(10, 15, 30, 0.85), rgba(10, 15, 30, 0.95)), url('/Content/Images/courier-bg.jpg');
            background-size: cover;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            padding: 20px;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 2rem;
            padding: 3rem;
            box-shadow: 0 25px 60px rgba(0,0,0,0.5);
            max-width: 600px;
            width: 100%;
            text-align: center;
        }

        /* Star Rating System */
        .star-rating {
            display: flex;
            flex-direction: row-reverse;
            justify-content: center;
            gap: 10px;
            margin: 2rem 0;
        }

            .star-rating input {
                display: none;
            }

            .star-rating label {
                font-size: 3rem;
                color: #dee2e6;
                cursor: pointer;
                transition: 0.2s;
            }

                .star-rating label:hover,
                .star-rating label:hover ~ label,
                .star-rating input:checked ~ label {
                    color: #ffc107;
                }

        .shipment-brief {
            background: #f8f9fa;
            border-radius: 1rem;
            padding: 1.5rem;
            margin-bottom: 2rem;
            border: 1px solid #eee;
        }

        .btn-submit {
            background: #0d6efd;
            color: white;
            font-weight: 700;
            padding: 12px 30px;
            border-radius: 50px;
            border: none;
            width: 100%;
            transition: 0.3s;
        }

            .btn-submit:hover {
                background: #0b5ed7;
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(13,110,253,0.3);
            }

        .back-link {
            color: #6c757d;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
        }

            .back-link:hover {
                color: #212529;
            }
    </style>
</head>
<body>

    <div class="glass-panel">
        <h2 class="fw-bold text-dark mb-1">How was your delivery?</h2>
        <p class="text-muted mb-4">Your feedback helps us improve our fleet performance.</p>

        <!-- Shipment Summary -->
        <div class="shipment-brief">
            <div class="small text-uppercase fw-bold text-primary mb-1">Delivered Parcel</div>
            <h4 class="mb-0 fw-bold font-monospace">@Model.TrackingNumber</h4>
            <div class="text-muted small mt-1">Destination: @Model.ReceiverCity</div>
        </div>

        @using (Html.BeginForm("SubmitRating", "Customer", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="shipmentId" value="@Model.Id" />

            <!-- Interactive Stars -->
            <div class="star-rating">
                <input type="radio" id="star5" name="stars" value="5" required /><label for="star5" title="Excellent"><i class="bi bi-star-fill"></i></label>
                <input type="radio" id="star4" name="stars" value="4" /><label for="star4" title="Good"><i class="bi bi-star-fill"></i></label>
                <input type="radio" id="star3" name="stars" value="3" /><label for="star3" title="Average"><i class="bi bi-star-fill"></i></label>
                <input type="radio" id="star2" name="stars" value="2" /><label for="star2" title="Poor"><i class="bi bi-star-fill"></i></label>
                <input type="radio" id="star1" name="stars" value="1" /><label for="star1" title="Very Bad"><i class="bi bi-star-fill"></i></label>
            </div>

            <div class="mb-4 text-start">
                <label class="form-label fw-bold small text-muted text-uppercase">Share your experience (Optional)</label>
                <textarea name="comments" class="form-control" rows="4" placeholder="What did our driver do well? Or how can we improve?" style="border-radius: 1rem; resize: none;"></textarea>
            </div>

            <button type="submit" class="btn btn-submit shadow-sm mb-3">
                Post Public Rating
            </button>
        }

        <a href="@Url.Action("Details", new { id = Model.Id })" class="back-link">
            <i class="bi bi-arrow-left"></i> Return to Shipment Details
        </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
