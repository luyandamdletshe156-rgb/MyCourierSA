
@model MyCourierSA.Models.Shipment

@{
    ViewBag.Title = "Complete Delivery";
    Layout = null; // Standalone layout for the dedicated driver app experience
}

<!-- Premium Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="complete-delivery-wrapper">
    <div class="container d-flex justify-content-center align-items-center min-vh-100 py-5">

        <div class="delivery-card shadow-lg w-100" style="max-width: 600px;">

            <!-- Card Header -->
            <div class="delivery-header text-center mb-4">
                <div class="success-icon mx-auto mb-3">
                    <i class="fas fa-box-open"></i>
                </div>
                <h3 class="fw-bold mb-1 text-main">Complete Drop-off</h3>
                <p class="text-muted small mb-0">Record recipient details and upload Proof of Delivery.</p>
            </div>

            <!-- Parcel Details Box -->
            <div class="parcel-info-box mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-uppercase text-muted fw-bold small">Tracking Number</span>
                    <span class="badge bg-white text-dark border shadow-sm">#@Model.TrackingNumber</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-uppercase text-muted fw-bold small">Deliver To</span>
                    <span class="fw-bold text-main">@Model.ReceiverName</span>
                </div>
                <hr class="my-2 border-light" />
                <p class="small text-muted mb-0"><i class="fas fa-map-marker-alt me-1 text-success"></i> @Model.ReceiverAddress, @Model.ReceiverCity</p>
            </div>

            <!-- Error Summary (If controller validation fails) -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show small" role="alert">
                    <i class="fas fa-exclamation-circle me-1"></i>
                    @Html.ValidationSummary(true, "")
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Upload Form -->
            @using (Html.BeginForm("CompleteDelivery", "Driver", FormMethod.Post, new { enctype = "multipart/form-data", id = "deliveryForm" }))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("id", Model.Id)

                <!-- Recipient Name Input -->
                <div class="form-group mb-4">
                    <label for="recipientName" class="form-label fw-bold">Who signed for the parcel? <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="fas fa-user-edit"></i></span>
                        <input type="text" name="recipientName" id="recipientName" class="form-control custom-input border-start-0 ps-0" placeholder="e.g. John Doe (Reception)" required />
                    </div>
                </div>

                <!-- File Upload Input -->
                <div class="form-group mb-4">
                    <label for="proofOfDeliveryFile" class="form-label fw-bold">Proof of Delivery (Photo) <span class="text-danger">*</span></label>
                    <div class="file-upload-wrapper">
                        <input type="file" name="proofOfDeliveryFile" id="proofOfDeliveryFile" class="form-control custom-file-input" accept=".jpg,.jpeg,.png,.pdf" required />
                    </div>
                    <small class="text-muted mt-1 d-block"><i class="fas fa-info-circle me-1"></i> Accepted formats: JPG, PNG, PDF</small>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex gap-3 mt-2">
                    <a href="@Url.Action("Index", "Driver")" class="btn btn-outline-secondary flex-fill btn-lg form-btn">
                        Cancel
                    </a>
                    <button type="submit" class="btn btn-success flex-fill btn-lg form-btn shadow-sm" id="submitBtn" onclick="showLoader()">
                        <span id="btnText"><i class="fas fa-check-circle me-1"></i> Finish Delivery</span>
                        <span id="btnLoader" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function showLoader() {
        var form = document.getElementById('deliveryForm');
        if(form.checkValidity()) {
            document.getElementById('btnText').innerText = 'Uploading... ';
            document.getElementById('btnLoader').classList.remove('d-none');
            document.getElementById('submitBtn').classList.add('disabled');
        }
    }
</script>

<!-- ==========================================
     STYLES
=========================================== -->
<style>
    :root {
        --success-color: #10b981;
        --success-hover: #059669;
        --text-main: #1f2937;
        --text-muted: #6b7280;
        --bg-color: #f3f4f6;
        --radius-lg: 16px;
        --radius-md: 12px;
    }

    body {
        background-color: var(--bg-color);
        font-family: 'Poppins', sans-serif;
    }

    .complete-delivery-wrapper {
        color: var(--text-main);
    }

    .delivery-card {
        background: #ffffff;
        border-radius: var(--radius-lg);
        padding: 40px;
        border-top: 6px solid var(--success-color);
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: #ecfdf5;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .success-icon i {
            font-size: 2.5rem;
            color: var(--success-color);
        }

    .parcel-info-box {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: var(--radius-md);
        padding: 15px 20px;
    }

    .form-label {
        color: var(--text-main);
        font-size: 0.95rem;
    }

    .custom-input {
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
        box-shadow: none !important;
        padding: 12px 15px;
        background-color: #f9fafb;
    }

    .input-group-text {
        border-radius: var(--radius-md) 0 0 var(--radius-md);
        background-color: #f9fafb;
    }

    .custom-input:focus {
        border-color: var(--success-color);
        background-color: #ffffff;
    }

    .input-group:focus-within .input-group-text {
        border-color: var(--success-color);
        background-color: #ffffff;
        color: var(--success-color) !important;
    }

    .custom-file-input {
        border-radius: var(--radius-md);
        padding: 12px;
        border: 2px dashed #d1d5db;
        background-color: #f9fafb;
        cursor: pointer;
        transition: all 0.2s;
    }

        .custom-file-input:hover, .custom-file-input:focus {
            border-color: var(--success-color);
            background-color: #ecfdf5;
            box-shadow: none;
        }

    .form-btn {
        border-radius: var(--radius-md);
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.2s;
        padding: 12px;
    }

    .btn-success {
        background-color: var(--success-color);
        border: none;
    }

        .btn-success:hover {
            background-color: var(--success-hover);
            transform: translateY(-2px);
        }

    /* Mobile Adjustments */
    @@media (max-width: 576px) {
        .delivery-card {
            padding: 25px 20px;
        }
    }
</style>