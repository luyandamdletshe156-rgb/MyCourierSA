@model IEnumerable<MyCourierSA.Models.Shipment>
@using MyCourierSA.Constants
@using Microsoft.AspNet.Identity

@{
    ViewBag.Title = "Driver Console";
    Layout = null; // Standalone Premium View

    var pastDeliveries = ViewBag.PastDeliveries as IEnumerable<MyCourierSA.Models.Shipment> ?? new List<MyCourierSA.Models.Shipment>();
    var todayEarnings = ViewBag.DailyEarnings != null ? (decimal)ViewBag.DailyEarnings : 0.00m;

    // Progress calculation (Goal: R500/day)
    decimal dailyGoal = 500m;
    int goalProgress = (int)((todayEarnings / dailyGoal) * 100);
    if (goalProgress > 100) { goalProgress = 100; }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - MyCourierSA</title>

    <!-- Premium Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            --sidebar-width: 280px;
            --primary: #4361ee;
            --success: #06d6a0;
            --warning: #ffd166;
            --danger: #ef476f;
            --dark-bg: #0f172a;
            --glass-card: rgba(255, 255, 255, 0.95);
        }

        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f8fafc url('https://images.unsplash.com/photo-1519003722824-194d4455a60c?auto=format&fit=crop&w=1920&q=80') no-repeat center center fixed;
            background-size: cover;
            overflow: hidden;
        }

        .page-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.85) 0%, rgba(30, 41, 59, 0.5) 100%);
            z-index: -1;
        }

        .admin-wrapper {
            display: flex;
            height: 100vh;
        }

        /* SIDEBAR */
        .sidebar {
            width: var(--sidebar-width);
            background: rgba(15, 23, 42, 0.95);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255,255,255,0.1);
            display: flex;
            flex-direction: column;
            padding: 2.5rem 1.5rem;
            color: white;
            z-index: 100;
        }

        .nav-link {
            color: rgba(255,255,255,0.6);
            padding: 0.9rem 1.2rem;
            border-radius: 16px;
            margin-bottom: 0.5rem;
            transition: 0.3s;
            display: flex;
            align-items: center;
            text-decoration: none;
            font-weight: 600;
        }

        .nav-link i { width: 28px; font-size: 1.2rem; }
        .nav-link:hover, .nav-link.active {
            background: var(--primary);
            color: white;
            box-shadow: 0 10px 20px rgba(67, 97, 238, 0.3);
        }

        /* MAIN CONTENT */
        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 2.5rem;
        }

        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 3rem;
            color: white;
        }

        /* TASK CARDS */
        .task-card {
            background: var(--glass-card);
            border-radius: 24px;
            margin-bottom: 1.5rem;
            border: none;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            overflow: hidden;
            display: flex;
        }

        .task-accent { width: 10px; }
        .accent-pickup { background: var(--primary); }
        .accent-delivery { background: var(--success); }

        .btn-action {
            border-radius: 14px;
            padding: 12px 24px;
            font-weight: 700;
            border: none;
            transition: all 0.3s ease;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
        }

        .btn-action:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.15); }

        /* SIDEBAR CARDS */
        .glass-card {
            background: white;
            border-radius: 24px;
            padding: 1.8rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        .finance-widget {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            color: white;
            border: none;
        }

        .blink { animation: blinker 1.5s linear infinite; }
        @@keyframes blinker { 50% { opacity: 0.3; } }

        .smaller { font-size: 0.75rem; }
    </style>
</head>
<body>
    <div class="page-overlay"></div>

    <div class="admin-wrapper">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="mb-5 text-center">
                <h3 class="fw-800 mb-0"><i class="fas fa-shipping-fast text-primary me-2"></i>Courier<span class="text-primary">SA</span></h3>
                <span class="smaller text-white-50 fw-bold">DRIVER FLEET PORTAL</span>
            </div>

            <nav class="flex-grow-1">
                <a href="@Url.Action("Index", "Driver")" class="nav-link active">
                    <i class="fas fa-map-marked-alt"></i> My Route
                </a>
                <a href="@Url.Action("Earnings", "Driver")" class="nav-link">
                    <i class="fas fa-wallet"></i> Earnings
                </a>
                <a href="#" class="nav-link">
                    <i class="fas fa-clock-rotate-left"></i> History
                </a>
            </nav>

            @using (Html.BeginForm("LogOff", "Account", FormMethod.Post, new { id = "logoutForm" }))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-link bg-transparent border-0 w-100 text-danger">
                    <i class="fas fa-power-off"></i> Sign Out
                </button>
            }
        </aside>

        <!-- MAIN -->
        <main class="main-content">
            <header class="dashboard-header">
                <div>
                    <h1 class="fw-800 mb-1">Active Route</h1>
                    <p class="text-white-50 fw-600 mb-0">@DateTime.Now.ToString("dddd, dd MMMM")</p>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="text-end">
                        <div class="fw-bold fs-5">@User.Identity.Name</div>
                        <div class="badge bg-primary rounded-pill">ONLINE</div>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=4361ee&color=fff" class="rounded-circle shadow border border-2 border-white" width="55">
                </div>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4 fw-bold">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                </div>
            }

            <div class="row g-4">
                <div class="col-lg-8">
                    @if (!Model.Any())
                    {
                        <div class="glass-card text-center py-5 shadow-lg">
                            <i class="fas fa-check-double fa-4x text-success mb-3 opacity-25"></i>
                            <h3 class="fw-800">All Clear!</h3>
                            <p class="text-muted">You have no active shipments. Take a break or check back later.</p>
                        </div>
                    }

                    @foreach (var item in Model)
                    {
                        bool isPickup = item.Status == AppConstants.ShipmentStatuses.AssignedForPickup || item.Status == AppConstants.ShipmentStatuses.Collected;
                        string title = isPickup ? "PARCEL COLLECTION" : "FINAL DELIVERY";
                        string contactName = isPickup ? item.SenderName : item.ReceiverName;
                        string address = isPickup ? $"{item.SenderAddress}, {item.SenderCity}" : $"{item.ReceiverAddress}, {item.ReceiverCity}";
                        string phone = isPickup ? item.SenderPhone : item.ReceiverPhone;

                        <div class="task-card">
                            <div class="task-accent @(isPickup ? "accent-pickup" : "accent-delivery")"></div>
                            <div class="p-4 w-100">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <span class="badge bg-dark rounded-pill px-3 py-2 smaller fw-bold mb-2">@title</span>
                                        <h4 class="fw-800 mb-1">@contactName</h4>
                                        <div class="text-muted fw-600"><i class="fas fa-map-marker-alt text-danger me-2"></i>@address</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-800 text-primary mb-1">#@item.TrackingNumber</div>
                                        <span class="badge bg-light text-dark border">@item.Status</span>
                                    </div>
                                </div>

                                <hr class="opacity-10">

                                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                                    <div class="d-flex gap-2">
                                        <a href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(address)" target="_blank" class="btn btn-light rounded-pill px-3 fw-bold border"><i class="fas fa-location-arrow text-primary me-1"></i> Navigate</a>
                                        <a href="tel:@phone" class="btn btn-light rounded-pill px-3 fw-bold border"><i class="fas fa-phone text-success me-1"></i> Call</a>
                                    </div>

                                    @using (Html.BeginForm(null, null, FormMethod.Post, new { @class = "m-0" }))
                                    {
                                        @Html.AntiForgeryToken()
                                        @Html.Hidden("id", item.Id)

                                        if (item.Status == AppConstants.ShipmentStatuses.AssignedForPickup)
                                        {
                                            <button type="submit" formaction="@Url.Action("ConfirmCollection", "Driver")" class="btn btn-primary btn-action shadow-primary">
                                                <i class="fas fa-box me-2"></i> Confirm Collection
                                            </button>
                                        }
                                        else if (item.Status == AppConstants.ShipmentStatuses.Collected)
                                        {
                                            <button type="submit" formaction="@Url.Action("DropAtWarehouse", "Driver")" class="btn btn-warning btn-action">
                                                <i class="fas fa-warehouse me-2"></i> Handover at Warehouse
                                            </button>
                                        }
                                        else if (item.Status == AppConstants.ShipmentStatuses.AssignedForDelivery)
                                        {
                                            <button type="submit" formaction="@Url.Action("StartDelivery", "Driver")" class="btn btn-success btn-action text-white">
                                                <i class="fas fa-truck-fast me-2"></i> Start Delivery Route
                                            </button>
                                        }
                                        else if (item.Status == AppConstants.ShipmentStatuses.InTransit)
                                        {
                                            <div class="d-flex gap-2">
                                                <a href="@Url.Action("CompleteDelivery", "Driver", new { id = item.Id })" class="btn btn-success btn-action text-white flex-grow-1">
                                                    <i class="fas fa-signature me-2"></i> Complete Drop-off
                                                </a>
                                                <a href="@Url.Action("ReportIssue", "Driver", new { id = item.Id })" class="btn btn-outline-danger btn-action">
                                                    <i class="fas fa-exclamation-triangle"></i>
                                                </a>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- SIDEBAR STATS -->
                <div class="col-lg-4">
                    <div class="glass-card finance-widget shadow-lg">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <p class="text-white-50 small fw-800 text-uppercase m-0">Shift Earnings</p>
                            <i class="fas fa-wallet text-success fs-4"></i>
                        </div>
                        <h1 class="fw-800 mb-1">R @todayEarnings.ToString("N2")</h1>
                        <p class="smaller text-success fw-bold mb-4"><i class="fas fa-arrow-trend-up me-1"></i> Updated from wallet</p>

                        <div class="d-flex justify-content-between smaller fw-bold mb-2">
                            <span>Daily Progress</span>
                            <span>@goalProgress%</span>
                        </div>
                        <div class="progress mb-4" style="height: 8px; background: rgba(255,255,255,0.1); border-radius: 10px;">
                            <div class="progress-bar bg-success shadow-sm" style="width: @goalProgress%"></div>
                        </div>

                        <a href="@Url.Action("Earnings", "Driver")" class="btn btn-sm btn-outline-light w-100 rounded-pill fw-bold py-2">
                            Detailed Earnings <i class="fas fa-chevron-right ms-1"></i>
                        </a>
                    </div>

                    <div class="glass-card">
                        <h6 class="fw-800 text-dark mb-4 text-uppercase smaller">Route Summary</h6>
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-4 p-3 me-3"><i class="fas fa-box fs-5"></i></div>
                            <div>
                                <div class="fw-800 fs-5">@ViewBag.PickupCount</div>
                                <div class="smaller text-muted fw-bold">Pending Pickups</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <div class="bg-success bg-opacity-10 text-success rounded-4 p-3 me-3"><i class="fas fa-house-circle-check fs-5"></i></div>
                            <div>
                                <div class="fw-800 fs-5">@ViewBag.DeliveryCount</div>
                                <div class="smaller text-muted fw-bold">Pending Deliveries</div>
                            </div>
                        </div>
                    </div>

                    <div class="glass-card">
                        <h6 class="fw-800 text-dark mb-3 text-uppercase smaller">Recently Completed</h6>
                        @if (!pastDeliveries.Any())
                        {
                            <div class="text-center py-3 text-muted smaller fw-600">No deliveries recorded today.</div>
                        }
                        @foreach (var p in pastDeliveries)
                        {
                            <div class="d-flex justify-content-between align-items-center py-2 border-bottom border-light">
                                <div>
                                    <div class="fw-800 smaller text-dark">#@p.TrackingNumber</div>
                                    <div class="smaller text-muted">@p.ReceiverCity</div>
                                </div>
                                <div class="text-success fw-bold smaller">@p.EstimatedDeliveryDate.Value.ToString("HH:mm")</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>