@{
    Layout = null; // Makes it standalone (removes navbar/footer)
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Check Your Email - MyCourierSA</title>

    <!-- Bootstrap 5 & Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        }

        .account-page {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 1rem;
        }

        /* Glassmorphism Card Effect */
        .account-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            max-width: 450px;
            width: 100%;
            padding: 3.5rem 2.5rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

            .account-card h2 {
                color: #1a1a1a;
                font-weight: 800;
                letter-spacing: -0.5px;
            }

        .text-muted-custom {
            color: #6c757d;
            font-size: 1.05rem;
            line-height: 1.6;
        }

        /* Gradient Button */
        .btn-primary {
            background: linear-gradient(135deg, #6a11cb, #2575fc);
            border: none;
            border-radius: 12px;
            padding: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(37, 117, 252, 0.4);
                background: linear-gradient(135deg, #5b0ebd, #1f63d6);
                color: white;
            }
    </style>
</head>
<body>

    <main class="account-page">
        <div class="account-card text-center">

            <!-- Email Sent Icon -->
            <div class="mb-4">
                <i class="bi bi-envelope-check-fill text-primary" style="font-size: 3.5rem; background: -webkit-linear-gradient(#6a11cb, #2575fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
            </div>

            <h2 class="mb-3">Check Your Email</h2>
            <p class="text-muted-custom mb-4">
                If an account exists for the email you entered, we have sent a password reset link.
                Please check your inbox (and your spam folder) to continue.
            </p>

            <div class="d-grid mt-4">
                @Html.ActionLink("Back to Login", "Login", "Account", null, new { @class = "btn btn-primary btn-lg" })
            </div>
        </div>
    </main>

    <!-- Bootstrap Script -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>