@model MyCourierSA.Models.ExternalLoginConfirmationViewModel
@{
    ViewBag.Title = "Confirm Your Account";
}

<main class="account-page">
    <div class="account-container d-flex justify-content-center align-items-center vh-100">
        <div class="account-card p-5 shadow-lg rounded text-center">
            <h2 class="mb-3">Complete Your Registration</h2>
            <p class="mb-4 text-muted">
                You've successfully authenticated with <strong>@ViewBag.LoginProvider</strong>.
                Please enter your email to associate your account with MyCourier.
            </p>

            @using (Html.BeginForm("ExternalLoginConfirmation", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.Email)

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

                <div class="form-group mb-3 text-start">
                    @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Enter your email" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="d-grid mt-4">
                    <input type="submit" value="Confirm & Register" class="btn btn-primary btn-lg" />
                </div>
            }
            <p class="mt-4">
                @Html.ActionLink("Back to Login", "Login", "Account", null, new { @class = "btn btn-secondary btn-sm" })
            </p>
        </div>
    </div>
</main>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        .account-page {
            background: linear-gradient(135deg, #2575fc, #6a11cb);
            min-height: 100vh;
        }

        .account-container {
            padding: 1rem;
        }

        .account-card {
            background: #ffffffcc;
            border-radius: 15px;
            max-width: 450px;
            width: 100%;
        }

        .btn-primary, .btn-secondary {
            border-radius: 10px;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            }
    </style>
}