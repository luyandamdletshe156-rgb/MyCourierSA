@using MyCourierSA.Models
@model LoginViewModel
@{
    Layout = null;
    ViewBag.Title = "Secure Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier SA HQ</title>

    <!-- Google Fonts & Bootstrap 5 -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f8fafc;
            margin: 0;
            min-height: 100vh;
        }

        .login-container {
            /* Replace this with a real image path or a high-quality stock URL */
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.9) 0%, rgba(30, 41, 59, 0.8) 100%), url('https://images.unsplash.com/photo-1586769852044-692d6e3703f0?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 2rem;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            padding: 3rem;
        }

        .form-floating > .form-control,
        .form-floating > .form-select {
            border-radius: 1rem;
            border: 2px solid #e2e8f0;
            font-weight: 600;
        }

        .form-control:focus, .form-select:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
        }

        .btn-login {
            background: #0d6efd;
            color: white;
            border: none;
            border-radius: 1rem;
            padding: 1rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

            .btn-login:hover {
                background: #0b5ed7;
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(13, 110, 253, 0.2);
            }

        .role-badge {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 800;
            padding: 0.4rem 0.8rem;
            border-radius: 50rem;
            background: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
            margin-bottom: 1rem;
            display: inline-block;
        }

        .toggle-password {
            cursor: pointer;
            color: #64748b;
            transition: color 0.2s;
        }

            .toggle-password:hover {
                color: #0d6efd;
            }

        .back-to-site {
            position: absolute;
            top: 2rem;
            left: 2rem;
            color: white;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            opacity: 0.8;
            transition: opacity 0.2s;
        }

            .back-to-site:hover {
                opacity: 1;
                color: white;
            }
    </style>
</head>
<body>

    <div class="login-container">
        <a href="@Url.Action("Index", "Home")" class="back-to-site d-none d-md-flex">
            <i class="bi bi-arrow-left-circle-fill me-2 fs-4"></i> BACK TO PUBLIC SITE
        </a>

        <div class="glass-card shadow-2xl">
            <div class="text-center mb-5">
                <div class="role-badge">Secure Access Gateway</div>
                <h2 class="fw-800 text-slate-900 mb-2">Welcome Back</h2>
                <p class="text-muted small">Please identify your role and enter credentials.</p>
            </div>

            @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "needs-validation" }))
            {
                @Html.AntiForgeryToken()

                <!-- Error Messages -->
                if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 rounded-4 small mb-4 shadow-sm py-3 px-4">
                        <i class="bi bi-shield-exclamation me-2"></i>
                        @Html.ValidationSummary(true, "", new { @class = "list-unstyled mb-0 d-inline" })
                    </div>
                }

                <!-- Role Selector (Crucial for Redirection) -->
                <div class="form-floating mb-3">
                    <select name="Role" id="RoleSelector" class="form-select border-2" required>
                        <option value="Customer" selected>Personal Customer</option>
                        <option value="Driver">Fleet Logistics Driver</option>
                        <option value="Dispatcher">Regional Dispatcher</option>
                        <option value="Admin">System Administrator</option>
                    </select>
                    <label for="RoleSelector">Select Account Type</label>
                </div>

                <!-- Email Field -->
                <div class="form-floating mb-3">
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "name@example.com", type = "email", required = "required" })
                    <label>Email Address</label>
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small ps-2" })
                </div>

                <!-- Password Field -->
                <div class="form-floating mb-3 position-relative">
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", id = "pwdField", placeholder = "Password", required = "required" })
                    <label>Security Password</label>
                    <span class="position-absolute top-50 end-0 translate-middle-y me-3 toggle-password" id="eyeToggle">
                        <i class="bi bi-eye-fill fs-5"></i>
                    </span>
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small ps-2" })
                </div>

                <!-- Remember Me & Forgot Password -->
                <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                    <div class="form-check">
                        @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input", id = "rememberMe" })
                        <label class="form-check-label small text-muted fw-600" for="rememberMe">Remember me</label>
                    </div>
                    <a href="@Url.Action("ForgotPassword", "Account")" class="text-primary text-decoration-none small fw-bold">Forgot Password?</a>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn-login w-100 mb-4 shadow-sm">
                    Log In to Dashboard <i class="bi bi-chevron-right ms-2"></i>
                </button>

                <!-- Dynamic Registration Link (Only for Customers) -->
                <div id="registrationArea" class="text-center">
                    <span class="text-muted small">New to MyCourier?</span>
                    <a href="@Url.Action("Register", "Account")" class="text-primary text-decoration-none fw-800 small ms-1">Create Account</a>
                </div>
            }
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const roleSelect = document.getElementById('RoleSelector');
            const regArea = document.getElementById('registrationArea');
            const pwdField = document.getElementById('pwdField');
            const eyeToggle = document.getElementById('eyeToggle');

            // 1. Logic: Only Customers can see the Register link
            function updateUI() {
                if (roleSelect.value === "Customer") {
                    regArea.style.visibility = "visible";
                    regArea.style.opacity = "1";
                } else {
                    regArea.style.visibility = "hidden";
                    regArea.style.opacity = "0";
                }
            }

            roleSelect.addEventListener('change', updateUI);
            updateUI(); // Initial check

            // 2. Toggle Password Visibility
            eyeToggle.addEventListener('click', function () {
                const type = pwdField.getAttribute('type') === 'password' ? 'text' : 'password';
                pwdField.setAttribute('type', type);
                this.querySelector('i').classList.toggle('bi-eye-fill');
                this.querySelector('i').classList.toggle('bi-eye-slash-fill');
            });
        });
    </script>

</body>
</html>