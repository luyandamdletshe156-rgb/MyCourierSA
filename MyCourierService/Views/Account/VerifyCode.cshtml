@model MyCourierSA.Models.VerifyCodeViewModel
@{
    Layout = null; // Makes it standalone (removes navbar/footer)
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enter Verification Code - MyCourierSA</title>

    <!-- Bootstrap 5 & Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        }

        .account-page {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 1rem;
        }

        /* Glassmorphism Card Effect */
        .account-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
            max-width: 450px;
            width: 100%;
            padding: 3rem 2.5rem;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

            .account-card h2 {
                color: #1a1a1a;
                font-weight: 800;
                letter-spacing: -0.5px;
            }

        .text-muted-custom {
            color: #6c757d;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        /* Custom Input Styling */
        .input-group-text {
            background: #f8f9fa;
            border-right: none;
            border-radius: 12px 0 0 12px;
            color: #6a11cb;
        }

        .form-control {
            border-left: none;
            border-radius: 0 12px 12px 0;
            padding: 0.8rem 1rem;
            background: #f8f9fa;
        }

            .form-control:focus {
                background: #ffffff;
                box-shadow: none;
                border-color: #dee2e6;
            }

        .input-group:focus-within .input-group-text,
        .input-group:focus-within .form-control {
            background: #ffffff;
            border-color: #6a11cb;
            box-shadow: 0 0 0 0.25rem rgba(106, 17, 203, 0.1);
        }

        /* Custom Switch/Checkbox */
        .form-check-custom {
            background-color: #f8f9fa;
            padding: 0.8rem 1.2rem;
            border-radius: 12px;
            font-size: 0.95rem;
            color: #495057;
        }

        .form-switch .form-check-input {
            width: 3.5em;
            height: 1.75em;
            cursor: pointer;
        }

        .form-check-input:checked {
            background-color: #6a11cb;
            border-color: #6a11cb;
        }

        /* Gradient Button */
        .btn-primary {
            background: linear-gradient(135deg, #6a11cb, #2575fc);
            border: none;
            border-radius: 12px;
            padding: 0.8rem;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

            .btn-primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(37, 117, 252, 0.4);
                background: linear-gradient(135deg, #5b0ebd, #1f63d6);
            }
    </style>
</head>
<body>

    <main class="account-page">
        <div class="account-card text-center">

            <!-- Code Scan Icon -->
            <div class="mb-4">
                <i class="bi bi-upc-scan" style="font-size: 3rem; background: -webkit-linear-gradient(#6a11cb, #2575fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"></i>
            </div>

            <h2 class="mb-2">Enter Verification Code</h2>
            <p class="text-muted-custom mb-4">A code has been sent via your selected method. Please enter it below to complete your sign-in.</p>

            @using (Html.BeginForm("VerifyCode", "Account", new { ReturnUrl = Model.ReturnUrl }, FormMethod.Post, new { role = "form", @class = "text-start" }))
            {
                @Html.AntiForgeryToken()
                @Html.Hidden("provider", @Model.Provider)
                @Html.Hidden("rememberMe", @Model.RememberMe)

                @Html.ValidationSummary(false, "", new { @class = "text-danger" })

                <!-- Verification Code Input -->
                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-hash"></i></span>
                        @Html.TextBoxFor(m => m.Code, new { @class = "form-control", placeholder = "Enter 6-digit code" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Code, "", new { @class = "text-danger" })
                </div>

                <!-- Remember Browser Switch -->
                <div class="mb-4">
                    <div class="form-check form-switch form-check-custom d-flex justify-content-between align-items-center">
                        @Html.LabelFor(m => m.RememberBrowser, new { @class = "form-check-label" })
                        @Html.CheckBoxFor(m => m.RememberBrowser, new { @class = "form-check-input" })
                    </div>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">Submit &amp; Sign In</button>
                </div>
            }
        </div>
    </main>

    <!-- jQuery & Validation Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>