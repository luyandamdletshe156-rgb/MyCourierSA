@model MyCourierSA.Models.RegisterViewModel
@{
    Layout = null;
    ViewBag.Title = "Join MyCourier SA";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier SA</title>

    <!-- Google Fonts & Bootstrap 5 -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #f8fafc;
            margin: 0;
            min-height: 100vh;
        }

        .register-container {
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.9) 0%, rgba(30, 41, 59, 0.8) 100%), url('https://images.unsplash.com/photo-1566576721346-d4a3b4eaad5b?auto=format&fit=crop&q=80&w=2000');
            background-size: cover;
            background-position: center;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 2rem;
            width: 100%;
            max-width: 700px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            padding: 3rem;
        }

        .form-floating > .form-control,
        .form-floating > .form-select {
            border-radius: 1rem;
            border: 2px solid #e2e8f0;
            font-weight: 600;
        }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
        }

        .btn-register {
            background: #0d6efd;
            color: white;
            border: none;
            border-radius: 1rem;
            padding: 1rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

            .btn-register:hover {
                background: #0b5ed7;
                transform: translateY(-2px);
                box-shadow: 0 10px 20px rgba(13, 110, 253, 0.2);
            }

        .back-link {
            position: absolute;
            top: 2rem;
            left: 2rem;
            color: white;
            text-decoration: none;
            font-weight: 700;
            display: flex;
            align-items: center;
            opacity: 0.8;
            transition: opacity 0.2s;
        }

            .back-link:hover {
                opacity: 1;
                color: white;
            }

        .toggle-password {
            cursor: pointer;
            color: #64748b;
        }
    </style>
</head>
<body>

    <div class="register-container">
        <a href="@Url.Action("Index", "Home")" class="back-link d-none d-md-flex">
            <i class="bi bi-arrow-left-circle-fill me-2 fs-4"></i> BACK TO HOME
        </a>

        <div class="glass-card shadow-2xl">
            <div class="text-center mb-4">
                <div class="badge bg-primary bg-opacity-10 text-primary mb-2 px-3 py-2 rounded-pill fw-800">CUSTOMER REGISTRATION</div>
                <h2 class="fw-800 text-slate-900 mb-1">Create Account</h2>
                <p class="text-muted small">Enter your details to start shipping across SA.</p>
            </div>

            @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()

                if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger border-0 rounded-4 small mb-4 py-3">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        @Html.ValidationSummary(true, "", new { @class = "list-unstyled mb-0 d-inline" })
                    </div>
                }

                <div class="row g-3">
                    <!-- Name & Surname -->
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "John" })
                            <label>First Name</label>
                            @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger small ps-2" })
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            @Html.TextBoxFor(m => m.Surname, new { @class = "form-control", placeholder = "Doe" })
                            <label>Last Name</label>
                            @Html.ValidationMessageFor(m => m.Surname, "", new { @class = "text-danger small ps-2" })
                        </div>
                    </div>

                    <!-- Email & Phone -->
                    <div class="col-md-7">
                        <div class="form-floating mb-3">
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control", type = "email", placeholder = "name@example.com" })
                            <label>Email Address</label>
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small ps-2" })
                        </div>
                    </div>
                    <div class="col-md-5">
                        <div class="form-floating mb-3">
                            @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control", placeholder = "082..." })
                            <label>Mobile Number</label>
                            @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger small ps-2" })
                        </div>
                    </div>

                    <!-- Address -->
                    <div class="col-12">
                        <div class="form-floating mb-3">
                            @Html.TextAreaFor(m => m.Address, new { @class = "form-control", style = "height: 100px", placeholder = "Address" })
                            <label>Home/Office Address</label>
                            @Html.ValidationMessageFor(m => m.Address, "", new { @class = "text-danger small ps-2" })
                        </div>
                    </div>

                    <!-- Passwords -->
                    <div class="col-md-6">
                        <div class="form-floating mb-3 position-relative">
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control pwd-input", id = "pwdMain", placeholder = "Password" })
                            <label>Password</label>
                            <span class="position-absolute top-50 end-0 translate-middle-y me-3 toggle-password">
                                <i class="bi bi-eye-fill fs-5"></i>
                            </span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control pwd-input", placeholder = "Confirm" })
                            <label>Confirm Password</label>
                        </div>
                    </div>
                </div>

                <div class="form-check mb-4 mt-2 px-4">
                    <input class="form-check-input" type="checkbox" required id="terms">
                    <label class="form-check-label small text-muted fw-600" for="terms">
                        I agree to the <a href="#" class="text-primary text-decoration-none fw-bold">Terms of Service</a>
                    </label>
                </div>

                <button type="submit" class="btn-register w-100 shadow-sm mb-4">
                    Complete Registration <i class="bi bi-check-circle-fill ms-2"></i>
                </button>

                <div class="text-center">
                    <span class="text-muted small">Already have an account?</span>
                    <a href="@Url.Action("Login", "Account")" class="text-primary text-decoration-none fw-800 small ms-1">Sign In</a>
                </div>
            }
        </div>
    </div>

    <!-- Script for Password Visibility -->
    <script>
        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', function () {
                const inputs = document.querySelectorAll('.pwd-input');
                const isPwd = inputs[0].type === 'password';
                inputs.forEach(i => i.type = isPwd ? 'text' : 'password');
                this.querySelector('i').classList.toggle('bi-eye-fill');
                this.querySelector('i').classList.toggle('bi-eye-slash-fill');
            });
        });
    </script>
</body>
</html>