@{
    Layout = null;
    ViewBag.Title = "Welcome to MyCourier";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier SA</title>

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f8f9fa;
            color: #333;
            overflow-x: hidden;
        }

        /* -------------------------
           1. SMART NAVBAR
           ------------------------- */
        .navbar {
            transition: all 0.4s ease-in-out;
            padding: 1.5rem 0;
        }
        .navbar.scrolled {
            background: rgba(15, 30, 50, 0.95) !important;
            backdrop-filter: blur(10px);
            padding: 0.8rem 0;
            box-shadow: 0 5px 20px rgba(0,0,0,0.4);
        }
        .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 600;
            margin: 0 5px;
            transition: color 0.3s;
        }
        .nav-link:hover { color: #0dcaf0 !important; }

        /* -------------------------
           2. HERO SECTION
           ------------------------- */
        .landing-hero {
            background: linear-gradient(135deg, rgba(15, 30, 50, 0.85) 0%, rgba(10, 15, 25, 0.95) 100%), url('@Url.Content("~/Content/Images/courier-bg.jpg")');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
        }

        .gradient-text {
            background: linear-gradient(135deg, #0dcaf0 0%, #0d6efd 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Tracking Bar */
        .tracking-form-container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(15px);
            padding: 10px;
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            transition: transform 0.3s ease;
        }
        .tracking-form-container:focus-within {
            transform: translateY(-3px);
            box-shadow: 0 20px 40px rgba(13, 202, 240, 0.2);
            border-color: rgba(13, 202, 240, 0.5);
        }
        .tracking-input {
            background: transparent !important;
            border: none !important;
            color: white !important;
            box-shadow: none !important;
            text-transform: uppercase;
            font-size: 1.1rem;
            letter-spacing: 1px;
            padding-left: 20px;
        }
        .tracking-input::placeholder {
            color: rgba(255, 255, 255, 0.6);
            text-transform: none;
            letter-spacing: normal;
        }

        /* -------------------------
           3. FEATURE CARDS
           ------------------------- */
        .feature-card {
            background: #ffffff;
            border-radius: 1.25rem;
            transition: all 0.3s ease;
            border: 1px solid rgba(0,0,0,0.05);
            position: relative;
            overflow: hidden;
            z-index: 1;
        }
        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            border-color: rgba(13, 110, 253, 0.2);
        }
        .icon-bubble {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem auto;
            font-size: 2rem;
            transition: transform 0.3s ease;
        }
        .feature-card:hover .icon-bubble {
            transform: scale(1.1);
        }

        /* -------------------------
           4. CTA SECTION
           ------------------------- */
        .cta-section {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            border-radius: 2rem;
            padding: 4rem 2rem;
            margin: 4rem auto;
            box-shadow: 0 20px 40px rgba(13, 110, 253, 0.3);
        }

        /* -------------------------
           5. UTILITIES & ANIMATIONS
           ------------------------- */
        .hover-white {
            transition: color 0.3s ease;
        }
        .hover-white:hover {
            color: #ffffff !important;
        }

        .fade-up {
            animation: fadeUp 1s ease-out forwards;
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-bounce {
            animation: bounce 2s infinite;
        }
        @@keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-15px); }
            60% { transform: translateY(-7px); }
        }
    </style>
</head>
<body>

    <!-- SMART NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-transparent fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4 d-flex align-items-center" href="@Url.Action("Index", "Home")">
                <i class="bi bi-box-seam-fill text-info me-2 fs-3"></i> MyCourier
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("About", "Home")">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Contact", "Home")">Contact</a></li>
                    <li class="nav-item ms-lg-3 mt-3 mt-lg-0">
                        <a class="btn btn-info text-dark fw-bold rounded-pill px-4 shadow-sm" href="@Url.Action("Login", "Account")">
                            <i class="bi bi-person-circle me-1"></i> Client Portal
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <main class="landing-hero">
        <div class="container text-center text-white fade-up">
            <span class="badge bg-white bg-opacity-25 border border-light border-opacity-25 px-3 py-2 rounded-pill mb-4 fw-bold" style="letter-spacing: 1px;">
                <i class="bi bi-lightning-charge-fill text-warning me-1"></i> FAST & RELIABLE LOGISTICS
            </span>

            <h1 class="display-2 fw-bolder mb-3">Your Delivery, <span class="gradient-text">Our Priority.</span></h1>
            <p class="lead mb-5 mx-auto opacity-75" style="max-width: 700px;">
                Experience seamless logistics management, real-time parcel tracking, and dedicated support—all in one smart platform built for South Africa.
            </p>

            <!-- Tracking Form -->
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    @using (Html.BeginForm("Index", "Tracking", FormMethod.Post, new { id = "trackForm", @class = "mb-4" }))
                    {
                        @Html.AntiForgeryToken()
                        <div class="tracking-form-container d-flex">
                            <input type="text" name="trackingNumber" id="trackingInput" class="form-control tracking-input" placeholder="Enter Tracking Number..." required autocomplete="off" aria-label="Tracking Number" />
                            <button type="submit" class="btn btn-info text-dark rounded-pill px-4 fw-bold shadow-sm">
                                <i class="bi bi-search me-1"></i> Track
                            </button>
                        </div>
                    }

                    <div class="mt-4 pt-2 d-flex justify-content-center gap-3">
                        <a href="@Url.Action("Register", "Account")" class="btn btn-primary rounded-pill px-4 py-2 fw-bold shadow-sm">Create Free Account</a>
                        <a href="#featuresSection" class="btn btn-outline-light rounded-pill px-4 py-2 fw-bold">Learn More</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div class="position-absolute bottom-0 start-50 translate-middle-x mb-4 opacity-50 d-none d-md-block">
            <i class="bi bi-chevron-down fs-2 text-white animate-bounce"></i>
        </div>
    </main>

    <!-- HOW IT WORKS SECTION -->
    <div class="container py-5 mt-5">
        <div class="text-center mb-5">
            <h6 class="text-primary fw-bold text-uppercase" style="letter-spacing: 1px;">Simple Process</h6>
            <h2 class="display-6 fw-bold text-dark">How It Works</h2>
        </div>
        <div class="row text-center g-4 position-relative">
            <div class="col-md-4">
                <div class="display-3 text-muted opacity-25 fw-bolder mb-2 position-absolute" style="top: -20px; left: 50px; z-index: 0;">1</div>
                <div class="position-relative z-1">
                    <i class="bi bi-box-seam text-primary fs-1 mb-3 d-block"></i>
                    <h4 class="fw-bold">Book Online</h4>
                    <p class="text-muted">Enter your parcel details, choose your destination, and get an instant quote.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="display-3 text-muted opacity-25 fw-bolder mb-2 position-absolute" style="top: -20px; left: 50%; z-index: 0;">2</div>
                <div class="position-relative z-1">
                    <i class="bi bi-truck text-primary fs-1 mb-3 d-block"></i>
                    <h4 class="fw-bold">We Collect</h4>
                    <p class="text-muted">Our friendly driver will collect your parcel directly from your home or office.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="display-3 text-muted opacity-25 fw-bolder mb-2 position-absolute" style="top: -20px; right: 50px; z-index: 0;">3</div>
                <div class="position-relative z-1">
                    <i class="bi bi-check2-circle text-primary fs-1 mb-3 d-block"></i>
                    <h4 class="fw-bold">Fast Delivery</h4>
                    <p class="text-muted">Track your parcel in real-time until it is safely delivered to the receiver.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- FEATURES SECTION -->
    <div class="bg-light py-5" id="featuresSection">
        <div class="container py-4">
            <div class="text-center mb-5">
                <h6 class="text-primary fw-bold text-uppercase" style="letter-spacing: 1px;">Why Choose Us</h6>
                <h2 class="display-6 fw-bold text-dark">Everything you need to send parcels</h2>
            </div>
            <div class="row text-center g-4">
                <div class="col-md-4">
                    <div class="card feature-card h-100 p-4 p-xl-5">
                        <div class="icon-bubble bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h4 class="fw-bold">Secure Logistics</h4>
                        <p class="text-muted mb-0">Every shipment is handled with care and comes with optional full-coverage insurance.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card feature-card h-100 p-4 p-xl-5">
                        <div class="icon-bubble bg-success bg-opacity-10 text-success">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <h4 class="fw-bold">Live Tracking</h4>
                        <p class="text-muted mb-0">Stay updated with exact GPS coordinates and real-time status updates via your dashboard.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card feature-card h-100 p-4 p-xl-5">
                        <div class="icon-bubble bg-info bg-opacity-10 text-info">
                            <i class="bi bi-wallet2"></i>
                        </div>
                        <h4 class="fw-bold">Digital Wallet</h4>
                        <p class="text-muted mb-0">Top up your secure digital wallet for instant, frictionless payments on bulk shipments.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- CALL TO ACTION SECTION -->
    <div class="container">
        <div class="cta-section text-center">
            <h2 class="display-5 fw-bold mb-3">Ready to send your first parcel?</h2>
            <p class="lead mb-4 opacity-75">Join thousands of businesses and individuals trusting MyCourier.</p>
            <a href="@Url.Action("Register", "Account")" class="btn btn-light btn-lg rounded-pill px-5 fw-bold text-primary shadow">
                Create Your Account
            </a>
            <div class="mt-3 small opacity-75">No credit card required to sign up.</div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="bg-dark text-white py-5 mt-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="fw-bold text-white mb-3"><i class="bi bi-box-seam-fill text-info me-2"></i>MyCourier</h5>
                    <p class="text-white-50 small">South Africa's premier technology-driven logistics partner, ensuring your parcels reach their destination safely and on time.</p>
                </div>
                <div class="col-md-4 text-md-center">
                    <h5 class="fw-bold text-white mb-3">Quick Links</h5>
                    <ul class="list-unstyled text-white-50 small line-height-lg">
                        <li class="mb-2"><a href="@Url.Action("Index", "Tracking")" class="text-white-50 text-decoration-none hover-white">Track Parcel</a></li>
                        <li class="mb-2"><a href="@Url.Action("About", "Home")" class="text-white-50 text-decoration-none hover-white">About Us</a></li>
                        <li class="mb-2"><a href="@Url.Action("Contact", "Home")" class="text-white-50 text-decoration-none hover-white">Contact Support</a></li>
                    </ul>
                </div>
                <div class="col-md-4 text-md-end">
                    <h5 class="fw-bold text-white mb-3">Connect With Us</h5>
                    <div class="d-flex justify-content-md-end gap-3">
                        <a href="#" class="text-white-50 fs-5" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-white-50 fs-5" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="text-white-50 fs-5" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>
            <hr class="border-secondary my-4">
            <div class="text-center text-white-50 small">
                &copy; @DateTime.Now.Year MyCourier South Africa. All rights reserved.
            </div>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // Feature 1: Smart Navbar Background on Scroll
            const nav = document.getElementById('mainNav');
            window.addEventListener('scroll', function () {
                if (window.scrollY > 50) {
                    nav.classList.add('scrolled');
                } else {
                    nav.classList.remove('scrolled');
                }
            });

            // Feature 2: Auto-Uppercase Tracking Input
            const trackingInput = document.getElementById('trackingInput');
            if (trackingInput) {
                trackingInput.addEventListener("input", function () {
                    this.value = this.value.toUpperCase();
                });
            }
        });
    </script>
</body>
</html>