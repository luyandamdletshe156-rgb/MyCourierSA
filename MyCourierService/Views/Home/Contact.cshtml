@{
    Layout = null;
    ViewBag.Title = "Contact Us";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier</title>

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            color: #333;
        }

        /* -------------------------
           1. SMART NAVBAR
           ------------------------- */
        .navbar {
            transition: all 0.4s ease-in-out;
            padding: 1.5rem 0;
        }
        .navbar.scrolled {
            background: rgba(15, 30, 50, 0.95) !important;
            backdrop-filter: blur(10px);
            padding: 0.8rem 0;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }

        /* -------------------------
           2. HERO SECTION
           ------------------------- */
        .contact-hero {
            background: linear-gradient(135deg, rgba(15, 30, 50, 0.85) 0%, rgba(10, 15, 25, 0.95) 100%), url('@Url.Content("~/Content/Images/courier-bg.jpg")');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 55vh;
            display: flex;
            align-items: center;
            color: white;
            position: relative;
        }

        /* -------------------------
           3. OVERLAPPING CARDS
           ------------------------- */
        .main-container {
            margin-top: -80px;
            position: relative;
            z-index: 10;
        }

        .info-card, .form-card {
            background: #ffffff;
            border-radius: 1.25rem;
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
            border: 1px solid rgba(0,0,0,0.05);
            padding: 2.5rem;
            height: 100%;
            transition: transform 0.3s ease;
        }

        .info-card:hover {
            transform: translateY(-5px);
            border-color: rgba(13, 110, 253, 0.2);
        }

        /* -------------------------
           4. MAP & ICONS
           ------------------------- */
        .icon-box {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            background: rgba(13, 110, 253, 0.1);
            color: #0d6efd;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin-right: 1rem;
        }

        .map-container {
            border-radius: 1rem;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            height: 250px;
            margin-top: 2rem;
        }

        .social-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- SMART NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-transparent fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4 d-flex align-items-center" href="@Url.Action("Index", "Home")">
                <i class="bi bi-box-seam-fill text-info me-2 fs-3"></i> MyCourier
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto fw-semibold">
                    <a class="nav-link text-white px-3" href="@Url.Action("Index", "Home")">Home</a>
                    <a class="nav-link text-white px-3" href="@Url.Action("Index", "Tracking")">Track Parcel</a>
                    <a class="btn btn-primary rounded-pill px-4 ms-lg-3 mt-2 mt-lg-0 shadow-sm fw-bold" href="@Url.Action("Index", "Customer")">Login</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="contact-hero text-center">
        <div class="container">
            <span class="badge bg-info text-dark px-3 py-2 rounded-pill mb-3 fw-bold" style="letter-spacing: 1px;">GET IN TOUCH</span>
            <h1 class="display-3 fw-bolder mb-3">We're Here To Help.</h1>
            <p class="lead text-light opacity-75 mx-auto" style="max-width: 600px;">
                Have a question about a shipment, our rates, or partnership opportunities? Send us a message and our team will get back to you shortly.
            </p>
        </div>
    </section>

    <!-- MAIN CONTENT -->
    <main class="container main-container pb-5 flex-grow-1">

        <!-- Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-3 mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-3 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="row g-4">

            <!-- LEFT COLUMN: CONTACT INFO & MAP -->
            <div class="col-lg-5">
                <div class="info-card">
                    <h3 class="fw-bold mb-4 text-dark">Contact Information</h3>

                    <div class="d-flex mb-4 align-items-center">
                        <div class="icon-box"><i class="bi bi-geo-alt-fill"></i></div>
                        <div>
                            <h6 class="fw-bold mb-1">Head Office</h6>
                            <p class="text-muted mb-0 small">123 Courier Lane, Umhlanga<br>Durban, KZN, 4320</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4 align-items-center">
                        <div class="icon-box bg-success bg-opacity-10 text-success"><i class="bi bi-telephone-fill"></i></div>
                        <div>
                            <h6 class="fw-bold mb-1">Call Us</h6>
                            <p class="text-muted mb-0 small">Support: 0800 123 456<br>Office: 031 555 0198</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4 align-items-center">
                        <div class="icon-box bg-warning bg-opacity-10 text-warning"><i class="bi bi-envelope-fill"></i></div>
                        <div>
                            <h6 class="fw-bold mb-1">Email Us</h6>
                            <p class="text-muted mb-0 small">support@mycourier.co.za<br>info@mycourier.co.za</p>
                        </div>
                    </div>

                    <hr class="my-4 text-muted">

                    <h6 class="fw-bold mb-3">Connect With Us</h6>
                    <div class="d-flex gap-2">
                        <a href="#" class="btn btn-outline-primary social-btn"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="btn btn-outline-dark social-btn"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="btn btn-outline-info social-btn"><i class="bi bi-linkedin"></i></a>
                        <a href="#" class="btn btn-outline-danger social-btn"><i class="bi bi-instagram"></i></a>
                    </div>

                    <!-- Interactive Map -->
                    <div class="map-container border">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d110793.07828454794!2d30.93888394462615!3d-29.730107901267433!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1ef7108920101b97%3A0x6b1cfb6920f3a61!2sUmhlanga%2C%20KwaZulu-Natal!5e0!3m2!1sen!2sza!4v1700000000000!5m2!1sen!2sza"
                                width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                </div>
            </div>

            <!-- RIGHT COLUMN: CONTACT FORM -->
            <div class="col-lg-7">
                <div class="form-card">
                    <h3 class="fw-bold mb-2 text-dark">Send a Message</h3>
                    <p class="text-muted mb-4">Fill out the form below and we will reply within 24 hours.</p>

                    @using (Html.BeginForm("SendMessage", "Contact", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input type="text" name="Name" class="form-control" id="Name" placeholder="John Doe" required>
                                    <label for="Name">Full Name</label>
                                    <div class="invalid-feedback">Please enter your name.</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input type="email" name="Email" class="form-control" id="Email" placeholder="name@example.com" required>
                                    <label for="Email">Email Address</label>
                                    <div class="invalid-feedback">Please enter a valid email address.</div>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <select name="Subject" class="form-select" id="Subject" required>
                                <option value="" disabled selected>Select an option...</option>
                                <option value="Tracking">Track a Shipment</option>
                                <option value="Rates">Get a Quote</option>
                                <option value="Support">General Support</option>
                                <option value="Partnership">Business Partnership</option>
                            </select>
                            <label for="Subject">How can we help?</label>
                            <div class="invalid-feedback">Please select a subject.</div>
                        </div>

                        <div class="form-floating mb-4">
                            <textarea name="Message" class="form-control" id="Message" placeholder="Leave a message here" style="height: 150px" required></textarea>
                            <label for="Message">Your Message</label>
                            <div class="invalid-feedback">Please write a message.</div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">
                            <i class="bi bi-send-fill me-2"></i> Send Message
                        </button>
                    }
                </div>
            </div>

        </div>
    </main>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center py-4 mt-auto">
        <div class="container">
            <p class="mb-0 text-white-50">&copy; @DateTime.Now.Year MyCourier South Africa. All rights reserved.</p>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // Feature 1: Smart Navbar Background on Scroll
            const nav = document.getElementById('mainNav');
            window.addEventListener('scroll', function () {
                if (window.scrollY > 50) {
                    nav.classList.add('scrolled');
                } else {
                    nav.classList.remove('scrolled');
                }
            });

            // Feature 2: Bootstrap Form Validation Script
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            });
        });
    </script>
</body>
</html>