@{
    Layout = null;
    ViewBag.Title = "About Us";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - MyCourier</title>

    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            color: #333;
        }

        /* -------------------------
           1. SMART NAVBAR
           ------------------------- */
        .navbar {
            transition: all 0.4s ease-in-out;
            padding: 1.5rem 0;
        }
        /* Applied via JS when user scrolls */
        .navbar.scrolled {
            background: rgba(15, 30, 50, 0.95) !important;
            backdrop-filter: blur(10px);
            padding: 0.8rem 0;
            box-shadow: 0 5px 20px rgba(0,0,0,0.3);
        }

        /* -------------------------
           2. HERO SECTION
           ------------------------- */
        .about-hero {
            background: linear-gradient(135deg, rgba(15, 30, 50, 0.85) 0%, rgba(10, 15, 25, 0.95) 100%), url('@Url.Content("~/Content/Images/courier-bg.jpg")');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            min-height: 65vh;
            display: flex;
            align-items: center;
            color: white;
            position: relative;
        }

        /* -------------------------
           3. OVERLAPPING GLASS CARD
           ------------------------- */
        .content-card {
            background: #ffffff;
            border-radius: 1.5rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            margin-top: -80px; /* Overlaps hero perfectly */
            position: relative;
            z-index: 10;
            padding: 4rem 3rem;
            border: 1px solid rgba(0,0,0,0.05);
        }

        /* -------------------------
           4. STATS ANIMATION
           ------------------------- */
        .stat-number {
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0;
            line-height: 1.2;
        }

        /* -------------------------
           5. VALUE CARDS (Mission/Vision)
           ------------------------- */
        .value-card {
            background: #f8f9fa;
            border-radius: 1rem;
            padding: 2.5rem 2rem;
            height: 100%;
            transition: all 0.3s ease;
            border: 1px solid transparent;
        }
        .value-card:hover {
            background: #ffffff;
            border-color: rgba(13, 110, 253, 0.2);
            box-shadow: 0 15px 30px rgba(0,0,0,0.05);
            transform: translateY(-5px);
        }
        .icon-box {
            width: 60px;
            height: 60px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
            color: white;
        }
        .bg-mission { background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%); }
        .bg-vision { background: linear-gradient(135deg, #198754 0%, #146c43 100%); }

        /* -------------------------
           6. TEAM SECTION
           ------------------------- */
        .team-card {
            text-align: center;
            transition: transform 0.3s ease;
        }
        .team-card:hover {
            transform: translateY(-10px);
        }
        .team-img {
            width: 160px;
            height: 160px;
            object-fit: cover;
            border-radius: 50%;
            border: 5px solid #fff;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            margin-bottom: 1.2rem;
            transition: border-color 0.3s ease;
        }
        .team-card:hover .team-img {
            border-color: #0d6efd;
        }
        .social-icons a {
            color: #adb5bd;
            font-size: 1.2rem;
            margin: 0 0.4rem;
            transition: color 0.2s ease;
        }
        .social-icons a:hover { color: #0d6efd; }
    </style>
</head>
<body>

    <!-- SMART NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-transparent fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4 d-flex align-items-center" href="@Url.Action("Index", "Home")">
                <i class="bi bi-box-seam-fill text-info me-2 fs-3"></i> MyCourier
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto fw-semibold">
                    <a class="nav-link text-white px-3" href="@Url.Action("Index", "Home")">Home</a>
                    <a class="nav-link text-white px-3" href="@Url.Action("Index", "Tracking")">Track Parcel</a>
                    <a class="btn btn-primary rounded-pill px-4 ms-lg-3 mt-2 mt-lg-0 shadow-sm fw-bold" href="@Url.Action("Index", "Customer")">Login</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="about-hero text-center">
        <div class="container">
            <span class="badge bg-info text-dark px-3 py-2 rounded-pill mb-3 fw-bold letter-spacing">DISCOVER OUR STORY</span>
            <h1 class="display-3 fw-bolder mb-3">Redefining Logistics.</h1>
            <p class="lead text-light opacity-75 mx-auto" style="max-width: 600px;">
                We are on a mission to provide the most reliable, affordable, and transparent courier services across South Africa.
            </p>
        </div>
    </section>

    <!-- MAIN CONTENT CARD -->
    <div class="container pb-5">
        <div class="content-card">

            <!-- STATS SECTION -->
            <div class="row text-center mb-5 pb-4 border-bottom g-4" id="statsSection">
                <div class="col-md-4">
                    <h2 class="stat-number" data-count="12500">0</h2>
                    <p class="text-muted fw-bold text-uppercase mt-2 letter-spacing">Parcels Delivered</p>
                </div>
                <div class="col-md-4">
                    <h2 class="stat-number" data-count="3200">0</h2>
                    <p class="text-muted fw-bold text-uppercase mt-2 letter-spacing">Active Users</p>
                </div>
                <div class="col-md-4">
                    <h2 class="stat-number" data-count="5800">0</h2>
                    <p class="text-muted fw-bold text-uppercase mt-2 letter-spacing">Successful Trips</p>
                </div>
            </div>

            <!-- MISSION & VISION -->
            <div class="row mb-5 pb-3 g-4">
                <div class="col-md-6">
                    <div class="value-card">
                        <div class="icon-box bg-mission shadow-sm">
                            <i class="bi bi-rocket-takeoff-fill"></i>
                        </div>
                        <h3 class="fw-bold mb-3 text-dark">Our Mission</h3>
                        <p class="text-muted mb-0 lh-lg">
                            To provide affordable, reliable, and transparent courier services that empower individuals and businesses to send parcels with absolute confidence across every province in South Africa.
                        </p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="value-card">
                        <div class="icon-box bg-vision shadow-sm">
                            <i class="bi bi-eye-fill"></i>
                        </div>
                        <h3 class="fw-bold mb-3 text-dark">Our Vision</h3>
                        <p class="text-muted mb-0 lh-lg">
                            To become South Africa’s most trusted logistics platform, known for technological innovation, unmatched customer satisfaction, and a commitment to sustainable, green delivery practices.
                        </p>
                    </div>
                </div>
            </div>

            <!-- LEADERSHIP TEAM -->
            <div class="text-center mb-5 mt-4">
                <span class="text-primary fw-bold text-uppercase tracking-wider">The People Behind The Tech</span>
                <h2 class="fw-bold text-dark mt-2 mb-4">Meet Our Leadership</h2>
            </div>

            <div class="row justify-content-center g-4">
                @{
                    var team = new[] {
                        new { Name = "Luyanda Mdletshe", Role = "Chief Executive Officer" },
                        new { Name = "Sphamandla Ntuli", Role = "Head of Operations" },
                        new { Name = "Nomvula Dlamini", Role = "Logistics Coordinator" }
                    };
                }

                @foreach (var member in team)
                {
                    <div class="col-md-4">
                        <div class="team-card">
                            <img src="@Url.Content("~/Content/Images/team.jpg")" class="team-img" alt="@member.Name" onerror="this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(member.Name)&background=0D8ABC&color=fff&size=200'">
                            <h5 class="fw-bold text-dark mb-1">@member.Name</h5>
                            <p class="text-primary small fw-bold text-uppercase mb-2">@member.Role</p>
                            <div class="social-icons">
                                <a href="#"><i class="bi bi-linkedin"></i></a>
                                <a href="#"><i class="bi bi-twitter"></i></a>
                                <a href="#"><i class="bi bi-envelope-fill"></i></a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- SIMPLE FOOTER -->
    <footer class="bg-dark text-white text-center py-4 mt-auto">
        <div class="container">
            <p class="mb-0 text-white-50">&copy; @DateTime.Now.Year MyCourier South Africa. All rights reserved.</p>
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // Feature 1: Smart Navbar Background on Scroll
            const nav = document.getElementById('mainNav');
            window.addEventListener('scroll', function () {
                if (window.scrollY > 50) {
                    nav.classList.add('scrolled');
                } else {
                    nav.classList.remove('scrolled');
                }
            });

            // Feature 2: Intersection Observer for Stats Counter
            // This ensures numbers only animate when the user scrolls them into view!
            const counters = document.querySelectorAll('.stat-number');
            const speed = 150; // The lower the slower

            const animateCounters = (counter) => {
                const target = +counter.getAttribute('data-count');
                const count = +counter.innerText.replace(/\+/g, '').replace(/,/g, '');
                const increment = target / speed;

                if (count < target) {
                    counter.innerText = Math.ceil(count + increment).toLocaleString() + "+";
                    setTimeout(() => animateCounters(counter), 20);
                } else {
                    counter.innerText = target.toLocaleString() + "+";
                }
            };

            const observerOptions = {
                threshold: 0.5 // Trigger when 50% of the element is visible
            };

            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        animateCounters(entry.target);
                        observer.unobserve(entry.target); // Stop observing once animated
                    }
                });
            }, observerOptions);

            counters.forEach(counter => {
                observer.observe(counter);
            });
        });
    </script>
</body>
</html>